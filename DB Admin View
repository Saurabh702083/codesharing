    private PayProcDetails resolveCardPayProcDetails(PaymentInitiationRequest request) {
        BinCheckRequest binCheckRequest = BinCheckRequest.builder()
                .cardBin(StringUtils.left(request.getAltNumber(), CARD_BIN_LENGTH))
                .build();
        BinCheckResponse binResponse = cardVerificationDao.validateBin(binCheckRequest);

        String payProcId = binResponse.getCardProcessor();
        String payProcType = STATE_BANK_NEW_PG.equals(binResponse.getBinIssuerId()) ? ONUS : OFFUS;
        String gtwMapsId = resolveCardGatewayMapId(binResponse);

        return new PayProcDetails(gtwMapsId, payProcId, payProcType);
