
  CREATE OR REPLACE FORCE EDITIONABLE VIEW "EPAYADMINPORTAL"."MV_JOURNEY" ("MERCHANT_ID", "MERCHANT_MIF_ID", "LEGAL_NAME", "BRAND_NAME", "BUSINESS_CATEGORY", "MERCHANT_SPOC", "EMAIL_ID", "PHONE_NUMBER", "MIF_SUBMISSION_DATE", "MIF_STATUS", "IS_DEVIATION", "DEVIATION_END_DATE", "DEVIATION_STATUS", "JOURNEY_INFO") AS 
  WITH journey_info AS (
    SELECT
        mj.merchant_mif_id,
        JSON_ARRAYAGG(
            JSON_OBJECT(
                'journeyId' VALUE mj.id,
                'journeyType' VALUE most.journey_type,
                'stageNum' VALUE most.stage_num,
                'stageCode' VALUE most.stage_code,
                'status' VALUE mj.status,
                'remarks' VALUE mj.remark,
                'updatedAt' VALUE mj.updated_at,

                'assignedUserDetails' VALUE (
                    SELECT JSON_ARRAYAGG(
                        JSON_OBJECT(
                            'userId' VALUE mau.user_id,
                            'userName' VALUE au.first_name,
                            'actionType' VALUE mau.action_type
                        )
                    )
                    FROM mif_journey_assigned_users mau
                    JOIN users au ON au.id = mau.user_id
                    WHERE mau.mif_journey_id = mj.id
                )

                RETURNING CLOB
            )
        ) AS journey_info
    FROM mif_journey mj
    LEFT JOIN merchant_onboarding_stages_master most
           ON most.stage_num = mj.stage_num
    GROUP BY mj.merchant_mif_id
)

SELECT DISTINCT
MM.MERCHANT_ID,
    mm.id                     AS merchant_mif_id,
    mm.legal_name,
    mm.brand_name,
    mbi.nature_of_business    AS business_category,
    mci.first_name            AS merchant_spoc,
    mci.email_id,
    mci.primary_mobile_number AS phone_number,
    mm.submission_date        AS mif_submission_date,
    mm.status                 AS mif_status,

    CASE
        WHEN mdi.document_type = 'DEVIATION_APPROVAL'
        THEN mdi.is_deviation
    END AS is_deviation,

    CASE
        WHEN mdi.document_type = 'DEVIATION_APPROVAL'
        THEN mdi.dev_end_date
    END AS deviation_end_date,

    CASE
        WHEN mdi.document_type = 'DEVIATION_APPROVAL'
        THEN mdi.status
    END AS deviation_status,

    jui.journey_info

FROM merchant_mif mm
JOIN mif_business_info mbi
     ON mm.id = mbi.merchant_mif_id
JOIN mif_contact_info mci
     ON mbi.merchant_mif_id = mci.merchant_mif_id
JOIN journey_info jui
     ON jui.merchant_mif_id = mm.id
LEFT JOIN mif_document_info mdi
     ON mm.id = mdi.merchant_mif_id;




