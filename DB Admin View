    // ---------- NB ----------

    private PayProcDetails resolveNetBankingPayProcDetails(PaymentInitiationRequest request, String mId) {
        String gtwMapsId = request.getGtwMapsId();
        JsonNode inbOptions = bookingDao.getMerchantPayModes(mId).path(OTHER_PAYMENT_OPTIONS).path("inb");

        String payProcId = streamArray(inbOptions)
                .filter(node -> gtwMapsId.equals(textOrNull(node, FIELD_GTW_MAPS_ID)))
                .findFirst()
                .map(node -> textOrNull(node, FIELD_PAYPROC))
                .orElseThrow(() -> new TransactionException(INVALID_ERROR_CODE,
                        MessageFormat.format(TransactionErrorConstants.INVALID_ERROR_MESSAGE,
                                "payProcId", "Could not resolve payProcId for gtwMapsId: " + gtwMapsId)));

        String payProcType = SELF.equalsIgnoreCase(payProcId) ? ONUS : OFFUS;

        return new PayProcDetails(gtwMapsId, payProcId, payProcType);
    }

    // ---------- UPI / WALLET ----------

    private PayProcDetails resolveUpiOrWalletPayProcDetails(PayMode payMode, PaymentInitiationRequest request, String mId) {
        String payProcId = request.getPayProcId();
        JsonNode paymentOptions = bookingDao.getMerchantPayModes(mId).path(OTHER_PAYMENT_OPTIONS);

        Stream<JsonNode> candidates = (payMode == PayMode.UPI)
                ? upiCandidates(paymentOptions.path("upi"))
                : streamArray(paymentOptions.path("wallet"));

        String gtwMapsId = candidates
                .filter(node -> payProcId.equalsIgnoreCase(textOrNull(node, FIELD_PAYPROC)))
                .findFirst()
                .map(node -> textOrNull(node, FIELD_GTW_MAPS_ID))
                .orElseThrow(() -> new TransactionException(INVALID_ERROR_CODE,
                        MessageFormat.format(TransactionErrorConstants.INVALID_ERROR_MESSAGE,
                                "gtwMapsId", "Could not resolve gtwMapsId for payProcId: " + payProcId)));

        return new PayProcDetails(gtwMapsId, payProcId, ONUS);
    }

    private Stream<JsonNode> upiCandidates(JsonNode upiNode) {
        // "self" and "BHIMQR" are individual object fields, not an array.
        return Stream.of(upiNode.path(SELF.toLowerCase()), upiNode.path(BHIMQR));
    }

    // ---------- shared JsonNode helpers ----------

    private Stream<JsonNode> streamArray(JsonNode arrayNode) {
        if (arrayNode == null || arrayNode.isMissingNode() || arrayNode.isNull()) {
            return Stream.empty();
        }
        return StreamSupport.stream(
                Spliterators.spliteratorUnknownSize(arrayNode.elements(), Spliterator.ORDERED), false);
    }

    private String textOrNull(JsonNode node, String fieldName) {
        if (node == null || node.isMissingNode() || node.isNull()) {
            return null;
        }
        JsonNode field = node.path(fieldName);
        return (field.isMissingNode() || field.isNull()) ? null : field.asText();
    }

