    public void validateSbiLogin(SbiAdminLoginReqDto sbiAdminReqDto) {
        logger.info("Validating SBI admin login request.");
        errorDtoList = new ArrayList<>();
        checkMandatoryField(sbiAdminReqDto.getUserName(), USER_NAME);
        checkMandatoryField(sbiAdminReqDto.getPassword(), PSW);
        throwIfErrors();
        checkForLeadingTrailingAndSingleSpace(sbiAdminReqDto.getUserName(), USER_NAME);
        checkForLeadingTrailingAndSingleSpace(sbiAdminReqDto.getPassword(), PSW);
        throwIfErrors();
        validateFieldLength(sbiAdminReqDto.getUserName(), MAX_USER_NAME_LENGTH, USER_NAME);
        validateFieldLength(sbiAdminReqDto.getPassword(), MAX_PASSWORD_LENGTH, PSW);
        throwIfErrors();
        validateFieldWithRegex(sbiAdminReqDto.getUserName(), USER_NAME_REGEX, USER_NAME, INVALID_FORMAT);
        throwIfErrors();
        MerchantUserDto sbiAdmin;
        try {
            sbiAdmin = adminDao.getMerchantIdByUserName(sbiAdminReqDto.getUserName());//will give active user details by userName
        } catch (MerchantException ex) {
            MerchantException merchantException = ex;
            if(StringUtils.equals(NOT_FOUND_ERROR_CODE, merchantException.getErrorCode())) {
                 merchantException = new MerchantException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, StringUtils.joinWith(" ", UserStatus.ACTIVE, USER)));
            }
            throw merchantException;
        }
        if (!StringUtils.equals(sbiAdmin.getPassword(), sbiAdminReqDto.getPassword()) && !adminDao.isSbiAdminRoleId(sbiAdmin.getRole())) {
            throw new ValidationException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, USER));
        }
    }
