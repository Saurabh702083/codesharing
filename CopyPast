   public EisPurposeResponse getConsentPurpose(String aesKey, String eisEncryptionKey, String encryptedRequest) {
        EisConsentResponse eisResponse = eisServicesClient.postEncryptedRequest(aesKey, eisEncryptionKey,encryptedRequest, EisConsentResponse.class);
        String decrypted = DCMSEISEncryptionDecryptionUtil.decrypt(eisResponse.getEncryptedResponse(),aesKey);
        logger.info("Decrypted EIS Response: {}", decrypted);
        try {
            return objectMapper.readValue(decrypted, EisPurposeResponse.class);
        }catch (JsonProcessingException e) {
            logger.error("Error parsing purpose response {}", e.getMessage());
            throw new CommunicationException(JSON_ERROR_CODE, MessageFormat.format(JSON_ERROR_MESSAGE, EIS_API));
        }
    }



    public <T> T postEncryptedRequest(String aesKey, String eisEncryptionKey, String encryptedRequest, Class<T> responseType){
        logger.info("Calling EIS Privacy Notice API");
        logger.info("AccessToken is : {}", eisEncryptionKey);
        URI uri = URI.create(getBaseUrl() + EIS_SERVICES_ENDPOINT);
        logger.info("EIS URI: {}",uri);
//        String safeToken = Base64.getUrlEncoder().withoutPadding().encodeToString(eisEncryptionKey.getBytes());
        String responseString = getWebClient().post()
                .uri(uri)
                .header("Content-Type", MediaType.APPLICATION_JSON_VALUE)
                .header("Accept", MediaType.APPLICATION_JSON_VALUE)
                .header("AccessToken", eisEncryptionKey)
//                .headers(httpHeaders -> httpHeaders.addAll(prepareHttpHeaders(safeToken)))
                .bodyValue(encryptedRequest)
                .retrieve()
                .onStatus(
                        httpStatus -> httpStatus.is4xxClientError() || httpStatus.is5xxServerError(),
                        clientResponse -> clientResponse.bodyToMono(String.class).flatMap(errorBody -> {
                            logger.error("EIS Service call failed with status: {}, error body: {}",
                                    clientResponse.statusCode().value(), errorBody); // 👈 log status & body
                            return Mono.error(new CommunicationException(
                                    "1001",
                                    MessageFormat.format(" is down", "EIS Service")
                            ));
                        })
                )
                .bodyToMono(new ParameterizedTypeReference<String>() {})
                .block();
        logger.info("RAW response received from EIS {}", responseString);
        return decryptResponse(aesKey, responseString, responseType);
    }

    private <T> T decryptResponse(String aesKey, String responseString, Class<T> responseType){
        try {
            logger.info("Decrypting EIS Response...");
            EisConsentResponse eisResponse = objectMapper.readValue(responseString, EisConsentResponse.class);
            String decrypted = DCMSEISEncryptionDecryptionUtil.decrypt(eisResponse.getEncryptedResponse(),aesKey);
            logger.info("Decrypted EIS Response: {}", decrypted);
//            logger.info("Decrypted eisPurposeMapper EIS Response: {}", eisPurposeMapper.convert(decrypted));
            return (T) eisResponse;
//            return (T) objectMapper.readValue(decrypted, EisResponse.class);
        } catch (JsonProcessingException e) {
            logger.error("Error decrypting privacy notice response {}", e.getMessage());
            throw new CommunicationException(JSON_ERROR_CODE, MessageFormat.format(JSON_ERROR_MESSAGE, EIS_API));
        }
    }
