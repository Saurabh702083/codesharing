package com.epay.admin.portal.master.handler;

import com.epay.admin.portal.exceptions.AdminPortalException;
import com.epay.admin.portal.master.dao.MasterWorkflowDao;
import com.epay.admin.portal.master.dao.NatureOfBusinessDao;
import com.epay.admin.portal.master.dto.request.NatureOfBusinessDto;
import com.epay.admin.portal.master.dto.request.NatureOfBusinessSearchRequest;
import com.epay.admin.portal.master.dto.response.NatureOfBusinessResponse;
import com.epay.admin.portal.master.entity.MasterWorkflow;
import com.epay.admin.portal.master.entity.NatureOfBusiness;
import com.epay.admin.portal.master.mapper.NatureOfBusinessMapper;
import com.epay.admin.portal.master.specification.NatureOfBusinessSpecification;
import com.epay.admin.portal.master.util.ENUM.ActionType;
import com.epay.admin.portal.master.util.ENUM.MasterStatus;
import com.epay.admin.portal.master.util.ENUM.MasterType;
import com.epay.admin.portal.master.util.ENUM.WorkflowStatus;
import com.epay.admin.portal.master.util.MasterUtil;
import com.epay.admin.portal.model.response.AdminPortalResponse;
import com.epay.admin.portal.util.EPayIdentityUtil;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.Pageable;
import org.springframework.stereotype.Component;

import java.text.MessageFormat;
import java.util.UUID;

import static com.epay.admin.portal.util.AdminPortalConstants.SUCCESS_RESPONSE_CODE;
import static com.epay.admin.portal.util.ErrorConstants.DUPLICATE_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.DUPLICATE_ERROR_MESSAGE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_MESSAGE;

@Component
public class NatureOfBusinessHandler extends AbstractMasterHandler<NatureOfBusinessDto, NatureOfBusiness> {

    private final NatureOfBusinessDao natureOfBusinessDao;
    private final NatureOfBusinessMapper natureOfBusinessMapper;

    public NatureOfBusinessHandler(NatureOfBusinessDao natureOfBusinessDao,
                                   MasterWorkflowDao masterWorkflowDao,
                                   ObjectMapper objectMapper,
                                   NatureOfBusinessMapper natureOfBusinessMapper) {
        super(masterWorkflowDao, objectMapper);
        this.natureOfBusinessDao = natureOfBusinessDao;
        this.natureOfBusinessMapper = natureOfBusinessMapper;
    }

    @Override public MasterType getMasterType() { return MasterType.NATURE_OF_BUSINESS; }
    @Override public Class<NatureOfBusinessDto> getDtoClass() { return NatureOfBusinessDto.class; }

    @Override
    public void validateCreate(NatureOfBusinessDto dto) {
        log.info("Validating nature of business create for natureOfBusinessName={}", dto.getNatureOfBusinessName());
        if (natureOfBusinessDao.existsByNatureOfBusinessName(dto.getNatureOfBusinessName())) {
            throw new AdminPortalException(DUPLICATE_ERROR_CODE, MessageFormat.format(DUPLICATE_ERROR_MESSAGE, "Nature of business name", dto.getNatureOfBusinessName()));
        }
    }

    @Override
    public MasterWorkflow createMaster(NatureOfBusinessDto dto) {
        log.info("Creating pending nature of business for natureOfBusinessName={}", dto.getNatureOfBusinessName());
        String makerId = EPayIdentityUtil.getUserPrincipal().getUsername();

        NatureOfBusiness entity = natureOfBusinessMapper.toEntity(dto);
        entity.setNatureOfBusinessCode(
                MasterUtil.generateMasterCode(dto.getNatureOfBusinessName(), MasterType.NATURE_OF_BUSINESS));
        entity.setStatus(MasterStatus.APPROVAL_PENDING.getValue());
        entity.setCreatedBy(makerId);

        NatureOfBusiness saved = natureOfBusinessDao.save(entity);

        MasterWorkflow workflow = MasterWorkflow.builder()
                .masterType(MasterType.NATURE_OF_BUSINESS)
                .masterCode(saved.getNatureOfBusinessCode())
                .recordId(saved.getId())
                .newValue(serializeEntity(saved, "nature of business create payload"))
                .status(WorkflowStatus.PENDING)
                .actionType(ActionType.CREATE.name())
                .makerId(makerId)
                .build();

        MasterWorkflow savedWorkflow = masterWorkflowDao.save(workflow);
        log.info("Nature of business workflow created workflowId={}", savedWorkflow.getId());
        return savedWorkflow;
    }

    @Override
    public AdminPortalResponse<?> search(JsonNode request, Pageable pageable) {
        log.info("Searching nature of business records pageable={}", pageable);
        NatureOfBusinessSearchRequest req =
                objectMapper.convertValue(request, NatureOfBusinessSearchRequest.class);
        Page<NatureOfBusiness> page =
                natureOfBusinessDao.findAll(NatureOfBusinessSpecification.build(req), pageable);
        return AdminPortalResponse.<NatureOfBusinessResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(page.getContent().stream().map(natureOfBusinessMapper::toResponse).toList())
                .count((long) page.getNumberOfElements())
                .total(page.getTotalElements())
                .build();
    }

    @Override
    public NatureOfBusiness findEntityById(UUID id) {
        return natureOfBusinessDao.findById(id)
                .orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE,
                        MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Nature of business with id=" + id)));
    }

    @Override public NatureOfBusiness saveEntity(NatureOfBusiness e) { return natureOfBusinessDao.save(e); }
    @Override public String getEntityStatus(NatureOfBusiness e) { return e.getStatus(); }
    @Override public void setEntityStatus(NatureOfBusiness e, String s) { e.setStatus(s); }
    @Override public String getEntityMasterCode(NatureOfBusiness e) { return e.getNatureOfBusinessCode(); }
}
