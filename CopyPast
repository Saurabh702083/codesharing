    private void validateMandatoryFields(UserEntityMappingRequest userEntityMappingRequest) {
        checkMandatoryField(userEntityMappingRequest.getEntityId(), MerchantConstant.ENTITY_ID);
        checkMandatoryFields(userEntityMappingRequest.getUserName(), userEntityMappingRequest.getUserId(), List.of(MerchantConstant.USER_NAME, MerchantConstant.USER_ID));
        throwIfErrors();
    }


    private boolean isEmpty(String value) {
        return StringUtils.isEmpty(StringUtils.strip(value));
    }


    private boolean isNotContainsNull(String value) {
        return !StringUtils.equalsAnyIgnoreCase(StringUtils.strip(value), "null");
    }


    private void validateValues(boolean isUserNamePresent, boolean isUserIdPresent) {
        if (!isUserNamePresent && !isUserIdPresent) {
            errorDtoList.add(ErrorDto.builder().errorCode(MANDATORY_ERROR_CODE).errorMessage(MessageFormat.format(MANDATORY_ERROR_MESSAGE, "value of userName or userId")).build());
        }
    }

 

    protected void checkMandatoryFields(String value1, String value2, Object... fieldNames) {
        if ((StringUtils.isEmpty(StringUtils.strip(value1)) || StringUtils.equalsAnyIgnoreCase(StringUtils.strip(value1), "null")) &&
                (StringUtils.isEmpty(StringUtils.strip(value2)) || StringUtils.equalsAnyIgnoreCase(StringUtils.strip(value2), "null"))) {
            addError( MessageFormat.format("Either {0} or {1}", MerchantConstant.USER_NAME , MerchantConstant.USER_ID), MANDATORY_ERROR_CODE, MANDATORY_ERROR_MESSAGE);
        }
    }

  
