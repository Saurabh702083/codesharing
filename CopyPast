package com.epay.admin.portal.master.specification;

import com.epay.admin.portal.master.dto.request.CityAreaPinCodeSearchRequest;
import com.epay.admin.portal.master.entity.CityAreaPincode;
import com.epay.admin.portal.master.entity.State;
import jakarta.persistence.criteria.Subquery;
import org.apache.commons.lang3.StringUtils;
import org.springframework.data.jpa.domain.Specification;

import java.util.UUID;

public final class CityAreaPincodeSpecification {

    private CityAreaPincodeSpecification() {
    }

    public static Specification<CityAreaPincode> build(CityAreaPinCodeSearchRequest request) {
        if (request == null) {
            return Specification.where(null);
        }
        return Specification.where(hasCityAreaName(request.getCityAreaName()))
                .and(hasStateName(request.getStateName()))
                .and(hasPinCode(request.getPinCode()))
                .and(hasStatus(request.getStatus()))
                .and(hasUpdatedAtBetween(request.getFromDate(), request.getToDate()));
    }

    private static Specification<CityAreaPincode> hasCityAreaName(String cityAreaName) {
        return (root, query, criteriaBuilder) -> StringUtils.isBlank(cityAreaName)
                ? criteriaBuilder.conjunction()
                : criteriaBuilder.like(
                        criteriaBuilder.lower(root.get("cityAreaName")),
                        "%" + cityAreaName.toLowerCase() + "%");
    }

    private static Specification<CityAreaPincode> hasStateName(String stateName) {
        return (root, query, criteriaBuilder) -> {
            if (StringUtils.isBlank(stateName)) {
                return criteriaBuilder.conjunction();
            }
            Subquery<UUID> subquery = query.subquery(UUID.class);
            var state = subquery.from(State.class);
            subquery.select(state.get("id"))
                    .where(criteriaBuilder.like(
                            criteriaBuilder.lower(state.get("stateName")),
                            "%" + stateName.toLowerCase() + "%"));
            return root.get("stateId").in(subquery);
        };
    }

    private static Specification<CityAreaPincode> hasPinCode(String pinCode) {
        return (root, query, criteriaBuilder) -> StringUtils.isBlank(pinCode)
                ? criteriaBuilder.conjunction()
                : criteriaBuilder.like(
                        criteriaBuilder.lower(root.get("pinCode")),
                        "%" + pinCode.toLowerCase() + "%");
    }

