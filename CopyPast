package com.epay.admin.portal.master.controller;

import com.epay.admin.portal.master.dto.request.MasterApprovalRequest;
import com.epay.admin.portal.master.dto.request.MasterInactivationRequest;
import com.epay.admin.portal.master.dto.response.BulkUploadResponse;
import com.epay.admin.portal.master.dto.response.MasterResponse;
import com.epay.admin.portal.master.service.AdminMasterService;
import com.epay.admin.portal.model.response.AdminPortalResponse;
import com.fasterxml.jackson.databind.JsonNode;
import com.sbi.epay.logging.utility.LoggerFactoryUtility;
import com.sbi.epay.logging.utility.LoggerUtility;
import lombok.RequiredArgsConstructor;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;
import org.springframework.data.web.PageableDefault;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;



@RestController
@RequestMapping("/api/v1/masters")
@RequiredArgsConstructor
public class MasterController {

    private final AdminMasterService masterService;
    public static final int DEFAULT_PAGE_SIZE = 10;
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());

    /**
     * MAKER — Submit create request.
     * POST /api/v1/masters/{masterType}
     *
     * Constitution:     { "constitutionName": "Partnership Firm" }
     * Country:          { "countryCode": "IN", "countryName": "India" }
     * CountryCurrency:  { "countryId": "uuid", "currencyCode": "INR", "currencyName": "Rupee" }
     *
     * Response: APPROVAL_PENDING, workflow PENDING
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_MANAGER')")
    @PostMapping("/{masterType}")
    public AdminPortalResponse<MasterResponse> createMaster(@PathVariable String masterType, @RequestBody JsonNode requestBody) {
        log.info("Create request received masterType={}", masterType);
        return masterService.submitCreate(masterType, requestBody);
    }

    /**
     * MAKER — Submit inactivation for one or more ACTIVE records.
     * POST /api/v1/masters/{masterType}/inactivate
     *
     * Body: { "masterIds": ["uuid1", "uuid2"], "remark": "No longer needed" }
     *
     * Response: INACTIVATION_PENDING, workflow INACTIVATION_PENDING
     * Fails if: record not ACTIVE, or parent has active children
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_MANAGER')")
    @PostMapping("/{masterType}/inactivate")
    public AdminPortalResponse<MasterResponse> inactivateMaster(@PathVariable String masterType, @RequestBody MasterInactivationRequest request) {
        log.info("Inactivate request received masterType={}", masterType);
        return masterService.submitInactivation(masterType, request);
    }

    /**
     * CHECKER — Approve pending records.
     * POST /api/v1/masters/{masterType}/approve
     *
     * Body: { "records": [{ "masterId": "uuid", "remark": "Looks good" }] }
     *
     * APPROVAL_PENDING     → entity ACTIVE,   workflow APPROVED
     * INACTIVATION_PENDING → entity INACTIVE, workflow APPROVED
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_CHECKER')")
    @PostMapping("/{masterType}/approve")
    public AdminPortalResponse<String> approve(@PathVariable String masterType, @RequestBody MasterApprovalRequest request) {
        log.info("Approve request received masterType={}", masterType);
        return masterService.approve(masterType, request);
    }

    /**
     * CHECKER — Reject pending records.
     * POST /api/v1/masters/{masterType}/reject
     *
     * Body: { "records": [{ "masterId": "uuid", "remark": "Invalid data" }] }
     *
     * APPROVAL_PENDING     → entity REJECTED, workflow REJECTED
     * INACTIVATION_PENDING → entity ACTIVE,   workflow REJECTED (rollback)
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_CHECKER')")
    @PostMapping("/{masterType}/reject")
    public AdminPortalResponse<String> reject(@PathVariable String masterType, @RequestBody MasterApprovalRequest request) {
        log.info("Reject request received masterType={}", masterType);
        return masterService.reject(masterType, request);
    }

    /**
     * MAKER — Bulk upload CSV.
     * POST /api/v1/masters/{masterType}/bulk
     * multipart/form-data, field name: "file"
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_MANAGER')")
    @PostMapping("/{masterType}/bulk")
    public AdminPortalResponse<BulkUploadResponse> bulkUpload(@PathVariable String masterType, @RequestParam("file") MultipartFile file) throws IOException {
        log.info("Bulk upload received masterType={} fileName={}", masterType, file.getOriginalFilename());
        return masterService.bulkUpload(masterType, file);
    }

    /**
     * BOTH — Search and paginate records.
     * POST /api/v1/masters/{masterType}/search
     *
     * Constitution: { "constitutionName": "HUF", "status": "ACTIVE" }
     * CountryCurrency: { "countryCode": "IN", "currencyCode": "INR", "status": "ACTIVE" }
     *
     * Supports fromDate/toDate (epoch ms) for modified date range filter.
     * Pageable via query params: ?page=0&size=10&sort=updatedAt,desc
     */
    @PreAuthorize("hasAnyRole('ONBOARDING_MANAGER', 'ONBOARDING_CHECKER')")
    @PostMapping("/{masterType}/search")
    public AdminPortalResponse<?> search(@PathVariable String masterType, @RequestBody JsonNode request, @PageableDefault(sort = "updatedAt", size = DEFAULT_PAGE_SIZE, direction = Sort.Direction.DESC) Pageable pageable) {
        log.info("Search request received masterType={} page={} size={}", masterType, pageable.getPageNumber(), pageable.getPageSize());
        return masterService.search(masterType, request, pageable);
    }
}
