@Service
@RequiredArgsConstructor
public class MasterWorkFlowService {
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());

    private final MasterWorkFlowRepository masterWorkFlowRepository;
    private final MasterWorkFlowMapper masterWorkFlowMapper;

    public void save(MasterWorkFlowDto masterWorkFlowDto,  WorkflowOperation operation){
        masterWorkFlowDto.setAction(operation.name());
        masterWorkFlowDto.setMakerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        MasterWorkFlow masterWorkFlow = masterWorkFlowMapper.mapEntityToDto(masterWorkFlowDto);
        masterWorkFlowRepository.save(masterWorkFlow);
    }

    public String approveWorkFlow(MasterType masterType, MasterApproveRejectRequest.RecordItem record) {
        MasterWorkFlow workFlow= masterWorkFlowRepository.findTopByMasterTypeAndRecordIdAndStatusInOrderByCreatedAtDesc(masterType, record.getMasterId(), List.of(WorkflowAction.PENDING, WorkflowAction.INACTIVATION_PENDING))
                .orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Pending workflow for masterId " + record.getMasterId())));
        workFlow.setRemark(record.getRemark());
        workFlow.setCheckerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        workFlow.setStatus(WorkflowAction.APPROVED.name());
        masterWorkFlowRepository.save(workFlow);
        log.info("Approved workflowId={} successfully for masterType={} and masterId={}", workFlow.getId(), masterType, record.getMasterId());
        return "Approved masterId " + record.getMasterId();
    }

    public String rejectWorkFlow(MasterType masterType, MasterApproveRejectRequest.RecordItem record) {
        MasterWorkFlow workFlow= masterWorkFlowRepository.findTopByMasterTypeAndRecordIdAndStatusInOrderByCreatedAtDesc(masterType, record.getMasterId(), List.of(WorkflowAction.PENDING, WorkflowAction.INACTIVATION_PENDING))
                .orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Pending workflow for masterId " + record.getMasterId())));
        workFlow.setRemark(record.getRemark());
        workFlow.setCheckerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        workFlow.setStatus(WorkflowAction.REJECTED.name());
        masterWorkFlowRepository.save(workFlow);
        log.info("Approved workflowId={} successfully for masterType={} and masterId={}", workFlow.getId(), masterType, record.getMasterId());
        return "Approved masterId " + record.getMasterId();
    }

    private String getRemarks(String operation){
       return StringUtils.EMPTY;
    }

}
