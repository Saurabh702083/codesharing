package admin.service;

import com.epay.admin.portal.dao.admin.AlertDao;
import com.epay.admin.portal.model.response.AdminPortalResponse;
import com.epay.admin.portal.model.response.AlertManagementResponse;
import com.epay.admin.portal.service.admin.AlertService;
import com.epay.admin.portal.util.EPayIdentityUtil;
import com.epay.admin.portal.validator.MerchantOnboardingValidator;
import com.sbi.epay.authentication.model.EPayPrincipal;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockedStatic;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageImpl;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;

import java.util.List;

import static com.epay.admin.portal.util.AdminPortalConstants.SUCCESS_RESPONSE_CODE;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.mockito.Mockito.mockStatic;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class AlertServiceTest {

    @InjectMocks
    private AlertService alertService;

    @Mock
    private AlertDao alertDao;

    @Mock
    private MerchantOnboardingValidator merchantOnboardingValidator;

    @Mock
    private EPayPrincipal principal;

    @Test
    void getUnreadAlertsByMId_shouldReturnUnreadAlertsForMerchant() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        AlertManagementResponse alert = AlertManagementResponse.builder()
                .alertIdentifier(101L)
                .alertDescription("Pending document review")
                .merchantMifId(merchantMifId)
                .isViewed(false)
                .createdAt(1000L)
                .build();
        Page<AlertManagementResponse> page = new PageImpl<>(List.of(alert), Pageable.unpaged(), 1);

        try (MockedStatic<EPayIdentityUtil> mockedStatic = mockStatic(EPayIdentityUtil.class)) {
            mockedStatic.when(EPayIdentityUtil::getUserPrincipal).thenReturn(principal);
            when(principal.getUsername()).thenReturn(userAdId);
            when(alertDao.getUnreadAlertsByMifId(merchantMifId, userAdId)).thenReturn(page);

            AdminPortalResponse<AlertManagementResponse> response = alertService.getUnreadAlertsByMId(merchantMifId);

            verify(merchantOnboardingValidator).validateMerchantOnBoardMIFId(merchantMifId);
            verify(alertDao).getUnreadAlertsByMifId(merchantMifId, userAdId);
            assertNotNull(response);
            assertEquals(SUCCESS_RESPONSE_CODE, response.getStatus());
            assertEquals(1L, response.getCount());
            assertEquals(1L, response.getTotal());
            assertEquals(List.of(alert), response.getData());
        }
    }

    @Test
    void getAllAlertsByUser_shouldReturnPagedAlertsForCurrentUser() {
        String userAdId = "user.ad";
        Pageable pageable = PageRequest.of(0, 10);
        AlertManagementResponse firstAlert = AlertManagementResponse.builder()
                .alertIdentifier(201L)
                .alertDescription("Alert one")
                .isViewed(false)
                .build();
        AlertManagementResponse secondAlert = AlertManagementResponse.builder()
                .alertIdentifier(202L)
                .alertDescription("Alert two")
                .isViewed(true)
                .build();
        Page<AlertManagementResponse> page = new PageImpl<>(List.of(firstAlert, secondAlert), pageable, 2);

        try (MockedStatic<EPayIdentityUtil> mockedStatic = mockStatic(EPayIdentityUtil.class)) {
            mockedStatic.when(EPayIdentityUtil::getUserPrincipal).thenReturn(principal);
            when(principal.getUsername()).thenReturn(userAdId);
            when(alertDao.getUnreadAlertsByUserId(userAdId, pageable)).thenReturn(page);

            AdminPortalResponse<AlertManagementResponse> response = alertService.getAllAlertsByUser(pageable);

            verify(alertDao).getUnreadAlertsByUserId(userAdId, pageable);
            assertNotNull(response);
            assertEquals(SUCCESS_RESPONSE_CODE, response.getStatus());
            assertEquals(2L, response.getCount());
            assertEquals(2L, response.getTotal());
            assertEquals(List.of(firstAlert, secondAlert), response.getData());
        }
    }

    @Test
    void updateAlertViewStatus_shouldValidateMerchantAndMarkAlertAsViewed() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        long alertIdentifier = 501L;

        try (MockedStatic<EPayIdentityUtil> mockedStatic = mockStatic(EPayIdentityUtil.class)) {
            mockedStatic.when(EPayIdentityUtil::getUserPrincipal).thenReturn(principal);
            when(principal.getUsername()).thenReturn(userAdId);

            AdminPortalResponse<String> response = alertService.updateAlertViewStatus(merchantMifId, alertIdentifier);

            verify(merchantOnboardingValidator).validateMerchantOnBoardMIFId(merchantMifId);
            verify(alertDao).updateViewStatus(merchantMifId, userAdId, alertIdentifier);
            assertNotNull(response);
            assertEquals(SUCCESS_RESPONSE_CODE, response.getStatus());
            assertEquals(1L, response.getTotal());
            assertEquals(List.of("View updated successfully"), response.getData());
        }
    }
}
