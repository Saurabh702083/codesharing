@Mapper(builder = @Builder(disableBuilder = true), componentModel = "spring")
public class MultiAccountSettlementMapper {
    /**
     * Maps the MIS Multi Account Settlement records to its corresponding DTO (Data Transfer Object).
     *
     * @param payments the entity to be converted
     * @param orders the entity to be converted
     * @param payouts the entity to be converted
     * @return the corresponding SettlementRecordResponse
     */
public List<SettlementRecordResponse> mapToResponse(List<MerchantOrderPaymentTxnMasProjection> payments, List<MerchantOrderTxn> orders, List<MerchantTxnPayout> payouts) {
        Map<String, MerchantOrderTxn> orderMap = orders.stream().collect(Collectors.toMap(MerchantOrderTxn::getSbiOrderRefNumber, o -> o, (a, b) -> a));
        Map<String, BigDecimal> payoutAmountByAtrn = payouts.stream().collect(Collectors.toMap(MerchantTxnPayout::getAtrnNum, MerchantTxnPayout::getTxnPayoutAmount, (a, b) -> a));
        List<SettlementRecordResponse> responses = new ArrayList<>();
        for (MerchantOrderPaymentTxnMasProjection payment : payments) {
            MerchantOrderTxn order = orderMap.get(payment.getSbiOrderRefNumber());
            OrderInfo orderInfo = OrderInfo.builder().sbiOrderRefNumber(payment.getSbiOrderRefNumber()).build();
            if(Objects.nonNull(order)) {
                orderInfo.setOrderRefNumber(order.getOrderRefNumber());
                orderInfo.setOrderStatus(order.getStatus());
                orderInfo.setCurrencyCode(order.getCurrencyCode());
                orderInfo.setOtherDetails(order.getOtherDetails());
                orderInfo.setMultiAccounts(order.getMultiAccounts());
            }
            BigDecimal orderAmount = ofNullable(payment.getOrderAmount()).orElse(ofNullable(order).map(MerchantOrderTxn::getOrderAmount).orElse(BigDecimal.ZERO));
            BigDecimal totalAmount = ofNullable(payment.getDebitAmount()).orElse(orderAmount);
            PaymentInfo.PaymentInfoBuilder paymentBuilder = PaymentInfo.builder().uniqueIdentifier(payment.getAccountUniqueIdentifier()).accountNumber(payment.getAccountNumber()).atrnNumber(payment.getAtrnNum()).orderAmount(orderAmount)
                    .totalAmount(totalAmount).transactionStatus(payment.getTransactionStatus()).payMode(payment.getPayMode()).bankName(payment.getChannelBank()).bankTxnNumber(payment.getBankReferenceNumber())
                    .currencyCode(payment.getCurrencyCode()).transactionTime(payment.getCreatedDate()).cin(payment.getCin());

            BigDecimal settlementAmount = payoutAmountByAtrn.get(payment.getAtrnNum());
            PaymentInfo paymentInfo = paymentBuilder.settlementAmount(settlementAmount).settlementStatus(payment.getSettlementStatus()).settlementDate(payment.getSettlementTime()).utrn(payment.getPaymentNarration()).build();
            responses.add(SettlementRecordResponse.builder().orderInfo(orderInfo).paymentInfo(Collections.singletonList(paymentInfo)).build());
        }
        return responses;
    }
