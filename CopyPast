    private void validateLeadingTrailingAndSingleSpace(UserEntityMappingRequest userEntityMappingRequest) {
        checkForLeadingTrailingAndSingleSpace(userEntityMappingRequest.getEntityId(), MerchantConstant.ENTITY_ID);
        if (!isEmpty(userEntityMappingRequest.getUserName()) && isNotContainsNull(userEntityMappingRequest.getUserName())) {
