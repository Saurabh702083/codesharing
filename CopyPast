package admin.dao;

import com.epay.admin.portal.dao.admin.AlertDao;
import com.epay.admin.portal.entity.admin.AlertManagement;
import com.epay.admin.portal.exceptions.AdminPortalException;
import com.epay.admin.portal.mapper.admin.AlertMapper;
import com.epay.admin.portal.model.response.AlertManagementResponse;
import com.epay.admin.portal.repository.admin.AlertManagementRepository;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageImpl;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;

import java.text.MessageFormat;
import java.util.List;
import java.util.Optional;
import java.util.UUID;

import static com.epay.admin.portal.util.AdminPortalConstants.ALERTIDENTIFIER;
import static com.epay.admin.portal.util.AdminPortalConstants.ALERTIDENTIFIER_ALREADY_UPDATED;
import static com.epay.admin.portal.util.AdminPortalConstants.DEFAULT_PAGE_NUMBER;
import static com.epay.admin.portal.util.AdminPortalConstants.DEFAULT_UNREAD_ALERT_SIZE;
import static com.epay.admin.portal.util.ErrorConstants.INVALID_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.INVALID_ERROR_MESSAGE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_MESSAGE;
import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.junit.jupiter.api.Assertions.assertNotNull;
import static org.junit.jupiter.api.Assertions.assertThrows;
