 private void validatePanDobYear(String dob) {
        if (StringUtils.isBlank(dob) || validate(dob, DATE_FORMAT_REGEX)) {
            return;
        }

        String fieldName = BUSINESS_INFO + PAN_DETAILS_INFO + PAN_HOLDER_DOB;
        LocalDate dobDate = parseSupportedDate(dob, fieldName);

        if (ObjectUtils.isNotEmpty(dobDate) && dobDate.getYear() < 1900) {
            addError(fieldName, INVALID_ERROR_CODE,
                    MessageFormat.format(INVALID_ERROR_MESSAGE, fieldName, "year should be greater than or equal to 1900"));
        }
    }

    private LocalDate parseSupportedDate(String inputDateString, String fieldName) {
        DateTimeFormatter[] formatters = {
                DateTimeFormatter.ofPattern(DATE_FORMAT),
                DateTimeFormatter.ofPattern("dd/MM/yyyy")
        };

        for (DateTimeFormatter formatter : formatters) {
            try {
                return LocalDate.parse(inputDateString, formatter);
            } catch (DateTimeParseException ignored) {
                // Try the next supported date format.
            }
        }

        addError(INVALID_ERROR_CODE, MessageFormat.format(INVALID_ERROR_MESSAGE, fieldName, INVALID_DATE_FORMAT_ERROR_MESSAGE));
        return null;
    }


 
