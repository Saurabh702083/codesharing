package com.epay.admin.portal.repository.admin.master;

import com.epay.admin.portal.entity.admin.master.Country;
import jakarta.transaction.Transactional;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;

import java.util.List;
import java.util.UUID;

public interface CountryRepository extends JpaRepository<Country, UUID> {
    @Transactional
    @Modifying
    @Query("UPDATE Country c SET c.status= :status WHERE c.id IN :masterIds")
    int updateStatus(@Param("masterIds")List<UUID> masterIds, @Param("status") String status);

    @Transactional
    @Modifying
    @Query("""
           UPDATE Country c SET c.status = CASE
            WHEN c.status='PENDING_FOR_APPROVAL' THEN 'ACTIVE'
            WHEN c.status='PENDING_FOR_INACTIVATION' THEN 'INACTIVE'
            ELSE c.status END
            WHERE c.id IN :ids
            """)
    int approve(@Param("ids") List<UUID> ids);


    @Transactional
    @Modifying
    @Query("""
            UPDATE Country c
            SET c.status =
            CASE
            WHEN c.status='PENDING_FOR_APPROVAL' THEN 'INACTIVE'
            WHEN c.status='PENDING_FOR_INACTIVATION' THEN 'ACTIVE'
            ELSE c.status END WHERE c.id IN :ids
            """)
    int reject(@Param("ids") List<UUID> ids);



    @Transactional
    @Modifying
    @Query("""
            UPDATE Country c
            SET c.status='PENDING_FOR_INACTIVATION' WHERE c.id IN :ids
            """)
    int markPendingForInactivation(@Param("ids") List<UUID> ids);

}
