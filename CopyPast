    private void validatedEntityId(MerchantEntityGroupRequest merchantEntityGroupRequest) {
        validateFieldLength(merchantEntityGroupRequest.getEntityId(), MerchantConstant.ENTITY_ID_LENGTH, MerchantConstant.ENTITY_ID);
        throwIfErrors();
