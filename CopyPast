 public ReportingResponse<SettlementRecordResponse> getMultiAccountSettlementRecords(String mId, MultiAccountSettlementSearchRequest masSearchRequest, Pageable pageable) {
        log.info("Multi Account Settlement status report request for MID: {}, payload: {}", mId, masSearchRequest);
        multiAccountSettlementValidator.validateRequest(mId,masSearchRequest,pageable);
        Page<MerchantOrderPaymentTxnMasProjection> paymentPage = reportDao.searchMultiAccountSettlementRecords(mId, masSearchRequest, pageable);
        List<MerchantOrderPaymentTxnMasProjection> payments = paymentPage.getContent();
        if (payments.isEmpty()) {
            return ReportingResponse.<SettlementRecordResponse>builder().status(RESPONSE_SUCCESS).data(Collections.emptyList()).count(0L).total(0L).build();
        }
        List<String> sbiOrderIds = payments.stream().map(MerchantOrderPaymentTxnMasProjection::getSbiOrderRefNumber).distinct().toList();
        List<MerchantOrderTxn> orders = settlementDao.findOrdersForPayments(mId, sbiOrderIds);
        List<String> atrnNumbers = payments.stream().map(MerchantOrderPaymentTxnMasProjection::getAtrnNum).distinct().toList();
        List<MerchantTxnPayout> payouts = settlementDao.findPayoutsForAtrns(mId, atrnNumbers);

        List<SettlementRecordResponse> responseList = masMapper.mapToResponse(payments, orders, payouts);
        return ReportingResponse.<SettlementRecordResponse>builder().status(RESPONSE_SUCCESS).data(responseList).count((long) responseList.size()).total(paymentPage.getTotalElements()).build();
    }

