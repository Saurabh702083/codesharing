    public BranchValidationResponse fetchBranchDetails(BranchValidationRequest branchValidationRequest) {
        BranchMaster branchMaster = StringUtils.isBlank(branchValidationRequest.getBranchName())
                ? branchMasterRepository.findByBranchCode(branchValidationRequest.getBranchCode())
                .orElseThrow(() -> new AdminPortalException(
