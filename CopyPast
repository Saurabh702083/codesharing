    private void validateRole(String userName) {
        MerchantUserDto merchantUserDto = merchantUserDao.getByUserName(userName, UserStatus.ACTIVE);
        if(ObjectUtils.isEmpty(merchantUserDto)) {
            throw new MerchantException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "User"));
        }
        if(ADMIN.equalsIgnoreCase(merchantUserDao.getRoleNameByRoleId(merchantUserDto.getRole()))) {
            throw new MerchantException(NOT_ALLOWED_ERROR_CODE, NOT_ALLOWED_ERROR_MESSAGE);
        }
    }

    public void validateConsentRequest(ConsentWriteRequest consentWriteRequest){
        errorDtoList = new ArrayList<>();
        logger.debug("Validation start for requestType {}",consentWriteRequest.getRequestType() );
        RequestType requestType=RequestType.getRequestType(consentWriteRequest.getRequestType());
        checkMandatoryField(consentWriteRequest.getRequestType(),REQUEST_TYPE);
        checkMandatoryField(consentWriteRequest.getRequestId(),REQUEST_ID);
        if(RequestType.PROFILE_CONTACT_EDIT.equals(requestType)){
            checkMandatoryField(consentWriteRequest.getNewEmail(),EMAIL);
            checkMandatoryField(consentWriteRequest.getNewMobileNumber(),MOBILE_PHONE);
            checkMandatoryField(consentWriteRequest.getMId(),MID);
        }
        throwIfErrors();
        checkForLeadingTrailingAndSingleSpace(consentWriteRequest.getRequestId(),REQUEST_ID);
        checkForLeadingTrailingAndSingleSpace(consentWriteRequest.getRequestType(),REQUEST_TYPE);
        checkForLeadingTrailingAndSingleSpace(consentWriteRequest.getNewEmail(),EMAIL);
        checkForLeadingTrailingAndSingleSpace(consentWriteRequest.getNewMobileNumber(),MOBILE_PHONE);
        throwIfErrors();
        validateFields(consentWriteRequest);


    }

    private void validateFields(ConsentWriteRequest consentWriteRequest) {
        validateFixedFieldLength(consentWriteRequest.getRequestId(), UUID_LENGTH, REQUEST_ID);
        validateFixedFieldLength(consentWriteRequest.getNewMobileNumber(), MOBILE_NUMBER_LENGTH, MOBILE_PHONE);
        validateFieldLength(consentWriteRequest.getNewEmail(), MAX_EMAIL_LENGTH, EMAIL);
        throwIfErrors();
        validateFieldWithRegex(consentWriteRequest.getNewEmail(), EMAIL_REGEX, EMAIL,INCORRECT_FORMAT);
        throwIfErrors();
    }

    public void validateContactDetails(ConsentWriteRequest request, MerchantDetailsResponse detail) {
        if (isSameMobileNumber(request, detail) && isSameEmailId(request, detail)) {
            throw new  MerchantException(INVALID_ERROR_CODE,MessageFormat.format(INVALID_ERROR_MESSAGE,"mobileNumber/email","Mobile number or email should be different from existing.") );
        }
    }

    public String validateAndGetFields(ConsentWriteRequest request, MerchantDetailsResponse detail) {
        StringJoiner sj = new StringJoiner(",");
        if (!isSameMobileNumber(request, detail)) {
            sj.add(MOBILE_NUMBER);
        }
        if (!isSameEmailId(request, detail)) {
            sj.add(EMAIL_ID);
        }
        return sj.toString();
    }

    private boolean isSameMobileNumber(ConsentWriteRequest consentRequest, MerchantDetailsResponse merchantDetail) {
        return consentRequest.getNewMobileNumber().equals(merchantDetail.getMobilePhone());
    }

    private boolean isSameEmailId(ConsentWriteRequest consentRequest, MerchantDetailsResponse merchantDetail) {
        return consentRequest.getNewEmail().equalsIgnoreCase(merchantDetail.getEmail());
    }
