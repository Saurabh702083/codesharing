    private void checkLeadingTrailingAndSingleSpace(MerchantBankAccountUpdateRequest merchantBankAccountUpdateRequest) {
        checkForLeadingTrailingAndSingleSpace(merchantBankAccountUpdateRequest.getAccountUniqueIdentifier(), ACCOUNT_UNIQUE_IDENTIFIER);
        checkForLeadingTrailingAndSingleSpace(merchantBankAccountUpdateRequest.getMId(), MerchantConstant.MID);
