package admin.validator;

import com.epay.admin.portal.exceptions.ValidationException;
import com.epay.admin.portal.master.dto.request.CityAreaPincodeDto;
import com.epay.admin.portal.master.dto.request.ConstitutionDTO;
import com.epay.admin.portal.master.dto.request.CountryCurrencyDTO;
import com.epay.admin.portal.master.dto.request.CountryDTO;
import com.epay.admin.portal.master.dto.request.MasterApprovalRequest;
import com.epay.admin.portal.master.dto.request.MasterInactivationRequest;
import com.epay.admin.portal.master.dto.request.StateDto;
import com.epay.admin.portal.master.util.ENUM.MasterType;
import com.epay.admin.portal.validator.MasterRequestValidator;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;

import java.util.List;
import java.util.UUID;

import static org.junit.jupiter.api.Assertions.assertDoesNotThrow;
import static org.junit.jupiter.api.Assertions.assertThrows;
import static org.junit.jupiter.api.Assertions.assertTrue;

class MasterRequestValidatorTest {

    private MasterRequestValidator validator;

    @BeforeEach
    void setUp() {
        validator = new MasterRequestValidator();
    }

    @Test
    void validateCreateRequest_shouldPass_whenCountryRequestIsValid() {
        CountryDTO request = new CountryDTO();
        request.setCountryCode("IN");
        request.setCountryName("India");

        assertDoesNotThrow(() -> validator.validateCreateRequest(MasterType.COUNTRY, request));
    }

    @Test
    void validateCreateRequest_shouldThrow_whenMandatoryFieldIsMissing() {
        ConstitutionDTO request = new ConstitutionDTO();

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateCreateRequest(MasterType.CONSTITUTION, request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("constitutionName"));
    }

    @Test
    void validateCreateRequest_shouldThrow_whenLeadingOrTrailingSpaceExists() {
        StateDto request = new StateDto();
        request.setStateName(" Maharashtra ");

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateCreateRequest(MasterType.STATE, request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("stateName"));
    }

    @Test
    void validateCreateRequest_shouldThrow_whenFieldExceedsMaxLength() {
        CountryCurrencyDTO request = new CountryCurrencyDTO();
        request.setCountryCode("IN");
        request.setCurrencyCode("TOO_LONG_CODE");
        request.setCurrencyName("Indian Rupee");

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateCreateRequest(MasterType.COUNTRY_CURRENCY, request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("currencyCode"));
    }

    @Test
    void validateCreateRequest_shouldThrow_whenPincodeFormatIsInvalid() {
        CityAreaPincodeDto request = new CityAreaPincodeDto();
        request.setCityAreaName("Mumbai");
        request.setStateName("Maharashtra");
        request.setPinCode("ABC123");

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateCreateRequest(MasterType.CITY_AREA_PINCODE, request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("pinCode"));
    }

    @Test
    void validateCreateRequest_shouldThrow_whenRequestBodyIsNull() {
        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateCreateRequest(MasterType.NATURE_OF_BUSINESS, null));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("request"));
    }

    @Test
    void validateInactivationRequest_shouldPass_whenRequestIsValid() {
        MasterInactivationRequest request = new MasterInactivationRequest();
        request.setMasterIds(List.of(UUID.randomUUID()));
        request.setRemark("No longer required");

        assertDoesNotThrow(() -> validator.validateInactivationRequest(request));
    }

    @Test
    void validateInactivationRequest_shouldThrow_whenMasterIdsAreMissing() {
        MasterInactivationRequest request = new MasterInactivationRequest();
        request.setRemark("No longer required");

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateInactivationRequest(request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("masterIds"));
    }

    @Test
    void validateApprovalRequest_shouldPass_whenRequestIsValid() {
        MasterApprovalRequest request = approvalRequest(UUID.randomUUID(), null);

        assertDoesNotThrow(() -> validator.validateApprovalRequest(request));
    }

    @Test
    void validateApprovalRequest_shouldThrow_whenMasterIdIsMissing() {
        MasterApprovalRequest request = approvalRequest(null, null);

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateApprovalRequest(request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("masterId"));
    }

    @Test
    void validateApprovalRequest_shouldThrow_whenDuplicateMasterIdIsProvided() {
        UUID masterId = UUID.randomUUID();
        MasterApprovalRequest request = new MasterApprovalRequest();
        request.setRecords(List.of(approvalItem(masterId, null), approvalItem(masterId, null)));

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateApprovalRequest(request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("masterId"));
    }

    @Test
    void validateRejectionRequest_shouldThrow_whenRemarkIsMissing() {
        MasterApprovalRequest request = approvalRequest(UUID.randomUUID(), null);

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateRejectionRequest(request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("remark"));
    }

    @Test
    void validateRejectionRequest_shouldThrow_whenRemarkHasLeadingSpace() {
        MasterApprovalRequest request = approvalRequest(UUID.randomUUID(), " Invalid data");

        ValidationException exception = assertThrows(
                ValidationException.class,
                () -> validator.validateRejectionRequest(request));

        assertTrue(exception.getErrorMessages().getFirst().getErrorMessage().contains("remark"));
    }

    private MasterApprovalRequest approvalRequest(UUID masterId, String remark) {
        MasterApprovalRequest request = new MasterApprovalRequest();
        request.setRecords(List.of(approvalItem(masterId, remark)));
        return request;
    }

    private MasterApprovalRequest.ApprovalItem approvalItem(UUID masterId, String remark) {
        MasterApprovalRequest.ApprovalItem item = new MasterApprovalRequest.ApprovalItem();
        item.setMasterId(masterId);
        item.setRemark(remark);
        return item;
    }
}
