private void validateTransactionAmount(BigDecimal orderAmount, BigDecimal transactionAmount) {
        logger.debug("Validating transactionAmount ");
        if (transactionAmount.compareTo(orderAmount) != 0) {
            addError(INVALID_ERROR_CODE, TransactionErrorConstants.INVALID_ERROR_MESSAGE, TRANSACTION_AMOUNT_FIELD, TRANSACTION_AMOUNT_FIELD_REASON);

        }
        throwIfErrors();
