 @Getter
@RequiredArgsConstructor
public enum MasterStatus {

    ACTIVE("ACTIVE"),

    INACTIVE("INACTIVE"),

    PENDING_FOR_APPROVAL("PENDING_FOR_APPROVAL"),

    PENDING_FOR_INACTIVATION("PENDING_FOR_INACTIVATION");

    private final String value;
}


@Getter
@RequiredArgsConstructor
public enum WorkflowOperation {

    CREATE,

    UPDATE,

    INACTIVATION
}


