                                MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Branch details")));

        return BranchValidationResponse.builder()
                .branchCode(branchMaster.getBranchCode())
                .branchName(branchMaster.getBranchName())
                .circleName(branchMaster.getCircleName())
                .circleCode(branchMaster.getCircleCode())
                .rmName(branchMaster.getRmName())
                .rmEmailId(branchMaster.getRmEmailId())
                .build();
    }
