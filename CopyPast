@Transactional
public AdminPortalResponse<String> inactivate(
        MasterInactivationRequest request,
        String masterCode) {

    MasterType master = MasterType.getMasterType(masterCode);

    BaseMasterService<BaseMasterDto> service =
            masterHandlerFactory.getMasterService(master.name());

    List<BaseMasterDto> masters =
            service.findByIds(request.getMasterIds());

    service.validateForInactivation(masters);

    service.markPendingForInactivation(request.getMasterIds());

    masters.forEach(masterDto -> {

        MasterWorkFlowDto workflow =
                service.mapToMasterWorkFlowDto(masterDto);

        workflow.setAction(WorkflowAction.INACTIVATE.name());

        workflow.setStatus(WorkflowAction.INACTIVATION_PENDING.name());

        workflow.setRemark(request.getRemark());

        masterWorkFlowService.save(
                workflow,
                WorkflowOperation.INACTIVATION);

    });

    return AdminPortalResponse.<String>builder()
            .status(SUCCESS_RESPONSE_CODE)
            .data(List.of("Masters submitted for inactivation successfully"))
            .build();
}

