import static com.epay.admin.portal.util.AdminPortalConstants.*;
import static com.epay.admin.portal.util.ErrorConstants.*;

/**
 * Class Name: AlertDao
 * Description: AlertDao is responsible for performing database operations related to alert management.
 * It interacts with repositories to manage and retrieve alert information, including alert masters and alert management records.
 * Additionally, it utilizes the `AlertMapper` for mapping data between entities and DTOs (Data Transfer Objects) for proper data processing.
 * The class also collaborates with the `MerchantInfoDao` to retrieve merchant-related information as part of the alert functionality.
 * <p>
 * Author: V1018841(Saurabh Mahto)
 * Copyright (c) 2026 [State Bank of India]
 * All rights reserved
 * Version: 1.0
 */

@Repository
@RequiredArgsConstructor
public class AlertDao {
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());
    private final AlertManagementRepository alertManagementRepository;
    private final AlertMapper alertMapper;


    /**
     * Retrieves all alerts for a given userAdId, with pagination.
     *
     * @param userAdId The userAdId for which the alerts are to be fetched.
     * @param pageable Pageable object for pagination settings.
     * @return A page of AlertManagementResponse objects representing all alerts for the given userAdId.
     */
    public Page<AlertManagementResponse> getUnreadAlertsByUserId(String userAdId, Pageable pageable) {
        return getAlertDescriptions(userAdId, true, pageable);
    }

    public Page<AlertManagementResponse> getAllAlertsByUserId(String userAdId, Pageable pageable) {
        return getAlertDescriptions(userAdId, false, pageable);
    }

    /**
     * Retrieves alerts for a given userAdId.
     *
     * @param userAdId The userAdId for which the alerts are to be fetched.
     * @param unreadOnly true to fetch only unread alerts, false to fetch all alerts.
     * @param pageable pagination settings.
     * @return A page of AlertManagementResponse objects representing the alerts for the given userAdId.
     */
    private Page<AlertManagementResponse> getAlertDescriptions(String userAdId, boolean unreadOnly, Pageable pageable) {
        log.info("getting alerts for userAdId :{} ", userAdId);
        Page<AlertManagement> alertManagementList = unreadOnly
                ? alertManagementRepository.findUnreadAlertsByUserId(userAdId, pageable)
                : alertManagementRepository.findAllAlertsByUserId(userAdId, pageable);
        List<AlertManagementResponse> responses = alertMapper.alertManagementEntityToResponse(alertManagementList.getContent());
        return new PageImpl<>(responses, pageable, alertManagementList.getTotalElements());
    }


    /**
     * Updates the view status of a specific alert for a given merchantMifId and alert identifier.
     * This method marks the alert as viewed by updating its view status in the database.
     *
     * @param alertIdentifier The unique identifier of the alert that needs to be updated.
     */
    public void updateViewStatus(String userAdId, long alertIdentifier) {
        log.info("Updating notification to view for userAdId :{0} ",userAdId);
        alertManagementRepository.findByUserAdIdAndAlertIdentifier(userAdId, alertIdentifier).map(alert -> {
            if (alert.isViewed()) {
                throw new AdminPortalException(INVALID_ERROR_CODE, MessageFormat.format(INVALID_ERROR_MESSAGE, ALERTIDENTIFIER, ALERTIDENTIFIER_ALREADY_UPDATED));
            }
            alert.setViewed(true);
            return alertManagementRepository.save(alert);
        }).orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, ALERTIDENTIFIER)));
    }

}
