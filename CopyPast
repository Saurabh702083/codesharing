import static org.mockito.Mockito.eq;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class AlertDaoTest {

    @InjectMocks
    private AlertDao alertDao;

    @Mock
    private AlertManagementRepository alertManagementRepository;

    @Mock
    private AlertMapper alertMapper;

    @Test
    void getUnreadAlertsByMifId_shouldFetchUnreadAlertsUsingDefaultPaging() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        AlertManagement entity = buildAlert(false);
        AlertManagementResponse response = AlertManagementResponse.builder()
                .alertIdentifier(entity.getAlertIdentifier())
                .alertDescription(entity.getAlertDescription())
                .merchantMifId(entity.getMerchantMifId())
                .isViewed(entity.isViewed())
                .build();
        Page<AlertManagement> page = new PageImpl<>(List.of(entity), PageRequest.of(0, 1), 1);
        Pageable expectedPageable = PageRequest.of(
                DEFAULT_PAGE_NUMBER,
                DEFAULT_UNREAD_ALERT_SIZE,
                Sort.by(Sort.Direction.DESC, "createdAt")
        );

        when(alertManagementRepository.findUnreadAlertsByMifId(eq(merchantMifId), eq(userAdId), eq(expectedPageable)))
                .thenReturn(page);
        when(alertMapper.alertManagementEntityToResponse(List.of(entity))).thenReturn(List.of(response));

        Page<AlertManagementResponse> result = alertDao.getUnreadAlertsByMifId(merchantMifId, userAdId);

        verify(alertManagementRepository).findUnreadAlertsByMifId(merchantMifId, userAdId, expectedPageable);
        verify(alertMapper).alertManagementEntityToResponse(List.of(entity));
        assertNotNull(result);
        assertEquals(1, result.getContent().size());
        assertEquals(response, result.getContent().getFirst());
        assertEquals(1L, result.getTotalElements());
    }

    @Test
    void getUnreadAlertsByUserId_shouldFetchUnreadAlertsForUserWithGivenPageable() {
        String userAdId = "user.ad";
        Pageable pageable = PageRequest.of(0, 5);
        AlertManagement entity = buildAlert(false);
        AlertManagementResponse response = AlertManagementResponse.builder()
                .alertIdentifier(entity.getAlertIdentifier())
                .alertDescription(entity.getAlertDescription())
                .merchantMifId(entity.getMerchantMifId())
                .isViewed(entity.isViewed())
                .build();
        Page<AlertManagement> page = new PageImpl<>(List.of(entity), pageable, 7);

        when(alertManagementRepository.findUnreadAlertsByUserId(userAdId, pageable)).thenReturn(page);
        when(alertMapper.alertManagementEntityToResponse(List.of(entity))).thenReturn(List.of(response));

        Page<AlertManagementResponse> result = alertDao.getUnreadAlertsByUserId(userAdId, pageable);

        verify(alertManagementRepository).findUnreadAlertsByUserId(userAdId, pageable);
        verify(alertMapper).alertManagementEntityToResponse(List.of(entity));
        assertEquals(1, result.getContent().size());
        assertEquals(7L, result.getTotalElements());
        assertEquals(response, result.getContent().getFirst());
    }

    @Test
    void updateViewStatus_shouldMarkAlertAsViewedAndSave() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        long alertIdentifier = 101L;
        AlertManagement alertManagement = buildAlert(false);
        alertManagement.setMerchantMifId(merchantMifId);
        alertManagement.setUserAdId(userAdId);
        alertManagement.setAlertIdentifier(alertIdentifier);

        when(alertManagementRepository.findByMerchantMifIdAndUserAdIdAndAlertIdentifier(merchantMifId, userAdId, alertIdentifier))
                .thenReturn(Optional.of(alertManagement));
        when(alertManagementRepository.save(alertManagement)).thenReturn(alertManagement);

        alertDao.updateViewStatus(merchantMifId, userAdId, alertIdentifier);

        verify(alertManagementRepository).save(alertManagement);
        assertEquals(true, alertManagement.isViewed());
    }

    @Test
    void updateViewStatus_shouldThrowExceptionWhenAlertAlreadyViewed() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        long alertIdentifier = 101L;
        AlertManagement alertManagement = buildAlert(true);
        alertManagement.setMerchantMifId(merchantMifId);
        alertManagement.setUserAdId(userAdId);
        alertManagement.setAlertIdentifier(alertIdentifier);

        when(alertManagementRepository.findByMerchantMifIdAndUserAdIdAndAlertIdentifier(merchantMifId, userAdId, alertIdentifier))
                .thenReturn(Optional.of(alertManagement));

        AdminPortalException exception = assertThrows(
                AdminPortalException.class,
                () -> alertDao.updateViewStatus(merchantMifId, userAdId, alertIdentifier)
        );

        verify(alertManagementRepository, never()).save(any());
        assertEquals(INVALID_ERROR_CODE, exception.getErrorCode());
        assertEquals(
                MessageFormat.format(INVALID_ERROR_MESSAGE, ALERTIDENTIFIER, ALERTIDENTIFIER_ALREADY_UPDATED),
                exception.getErrorMessage()
        );
    }

    @Test
    void updateViewStatus_shouldThrowExceptionWhenAlertNotFound() {
        String merchantMifId = "MIF12345";
        String userAdId = "user.ad";
        long alertIdentifier = 101L;

        when(alertManagementRepository.findByMerchantMifIdAndUserAdIdAndAlertIdentifier(merchantMifId, userAdId, alertIdentifier))
                .thenReturn(Optional.empty());

        AdminPortalException exception = assertThrows(
                AdminPortalException.class,
                () -> alertDao.updateViewStatus(merchantMifId, userAdId, alertIdentifier)
        );

        verify(alertManagementRepository, never()).save(any());
        assertEquals(NOT_FOUND_ERROR_CODE, exception.getErrorCode());
        assertEquals(
                MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, ALERTIDENTIFIER),
                exception.getErrorMessage()
        );
    }

    private AlertManagement buildAlert(boolean viewed) {
        return AlertManagement.builder()
                .id(UUID.randomUUID())
                .alertId(UUID.randomUUID())
                .merchantMifId("MIF00001")
                .userAdId("user.ad")
                .alertDescription("Test alert")
                .alertIdentifier(99L)
                .isViewed(viewed)
                .build();
    }
}
