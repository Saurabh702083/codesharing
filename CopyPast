    @Test
    void validateMerchantOnBoardMIFId_shouldThrow_whenFixedFieldLengthIsInvalid() {
        ValidationException exception = assertThrows(ValidationException.class, () -> merchantOnboardingValidator.validateMerchantOnBoardMIFId("122233344"));
        assertEquals(exception.getErrorMessages().getFirst().getErrorCode(), "8005");
        assert (exception.getErrorMessages().getFirst().getErrorMessage().contains("The fixed length required for merchantMIFId is 18."));
        assertEquals(exception.getErrorMessages().size(), 1);

    }

