@Transactional
public AdminPortalResponse<String> approveMaster(
        MasterApproveRejectRequest request,
        String masterCode) {

    MasterType master = MasterType.getMasterType(masterCode);

    BaseMasterService<BaseMasterDto> service =
            masterHandlerFactory.getMasterService(master.name());

    List<UUID> ids = request.getRecords()
            .stream()
            .map(MasterApproveRejectRequest.RecordItem::getMasterId)
            .toList();

    List<BaseMasterDto> masters = service.findByIds(ids);

    service.validateForApprove(masters);

    service.approve(ids);

    request.getRecords().forEach(record ->
            masterWorkFlowService.approveWorkFlow(master, record));

    return AdminPortalResponse.<String>builder()
            .status(SUCCESS_RESPONSE_CODE)
            .data(List.of("Masters approved successfully"))
            .build();
}


