    public void merchantSyncUp() {
        //Step1: Fetch merchant scheduler config by job name.
        List<OnboardingResponse> onboardingList;
        List<OnboardingFailedMerchantDto> badRecords;
        Optional<MerchantConfigDto> schedulerConfig = adminDao.getMerchantConfig(ONBOARDING);
        if(schedulerConfig.isPresent()) {
            //Step2: Fetch merchant details from admin's merchant info view.
            log.info("Calling admin service to get the merchant list for timestamp: {}", toDateTimeFormat(Long.valueOf(schedulerConfig.get().getValue())));
            onboardingList = adminDao.getAdminMerchants(Long.valueOf(schedulerConfig.get().getValue()));
            log.info("Got merchants[{}] from admin service.", CollectionUtils.size(onboardingList));
            log.debug("Admin service merchants: {}", onboardingList);
            if(CollectionUtils.isNotEmpty(onboardingList)) {
                //Step3: Onboard merchant in merchant-service.
                badRecords = onboardingList.stream().map(this::onboardingMerchant).filter(Objects::nonNull).toList();
                //Step4: Add bad records.
                if(CollectionUtils.isNotEmpty(badRecords)) {
                    log.info("Failed to onboard merchants: {}", badRecords);
                    adminDao.saveFailedOnboardingRecords(badRecords);
                }
                //Step5: Update merchant scheduler config.
                schedulerConfig.get().setValue(String.valueOf(DateTimeUtils.getCurrentTimeInMills()));
                adminDao.updateScheduleConfig(schedulerConfig.get());
            }
        } else {
            log.info("No Merchant config found for {}", ONBOARDING);
        }
    }


    public MerchantResponse<OnboardingApiResponse> onboardingMerchant(OnboardingRequest onboardingRequest) {
        log.info("Started onboardingRequest for merchant {}", onboardingRequest.getMerchant());
        //Step 1 : OnboardingRequest validation
        onboardingValidator.validateOnboardingRequest(onboardingRequest);
        //Step 2 : Set up the default value for Merchant
        setMerchantDefaultValues(onboardingRequest.getMerchant());
        //Step 3 : Save the Merchant and Merchant User Data in DB
        OnboardingDto onboardingDto = adminDao.onboardMerchant(onboardingRequest);
        //Step 5 : Build MerchantResponse and return to caller
        log.info("Returning OnboardingApiResponse for merchant");
        return MerchantResponse.<OnboardingApiResponse>builder().data(List.of(OnboardingApiResponse.builder().merchant(onboardingDto.getMerchant()).user(onboardingDto.getUser()).build())).status(RESPONSE_SUCCESS).total(1L).build();
    }


    protected OnboardingFailedMerchantDto onboardingMerchant(OnboardingResponse onboardingResponse) {
        log.info("Started onboardingRequest for mId: {}", onboardingResponse.getMerchant().getMId());
        log.debug("Admin Merchant Info: {}", onboardingResponse);
        try {
            var merchantInfoId = adminDao.getMerchantIdByMId(onboardingResponse.getMerchant().getMId());
            if (Objects.isNull(merchantInfoId)) {
                OnboardingRequest onboardingRequest = buildOnboardingRequest(onboardingResponse);
                // Step 1 : OnboardingRequest validation
                onboardingValidator.validateOnboardingRequest(onboardingRequest);
                // Step 2 : Set up the default value for Merchant
                setMerchantDefaultValues(onboardingRequest.getMerchant());
                // Step 3 : Save the Merchant and Merchant User Data in DB
                OnboardingDto onboardingDto = adminDao.onboardMerchant(onboardingRequest);
                // Step 4 : Build MerchantResponse and return to caller
                log.info("Merchant Onboarded mId: {}", onboardingDto.getMerchant().getMId());
            } else {
                onboardingValidator.validateUpdateRequest(merchantMapper.mapAdminDto(onboardingResponse.getMerchant()));
                adminDao.updateMerchantInfo(merchantInfoId, onboardingResponse.getMerchant());
            }
        } catch (ValidationException | MerchantException |
                 DataIntegrityViolationException | OptimisticLockingFailureException | JpaSystemException ex) {
            log.error("Onboarding/update failed for mId: {}, errors: {}", onboardingResponse.getMerchant().getMId(), ex.toString());
            try {
                return OnboardingFailedMerchantDto.builder()
                        .mId(onboardingResponse.getMerchant().getMId())
                        .onboardingJson(objectMapper.writeValueAsString(onboardingResponse))
                        .reason(ex.toString())
                        .correlationId(MDC.get(EPayAuthenticationConstant.CORRELATION_ID))
                        .build();
            } catch (JsonProcessingException e) {
                log.error("Failed to convert onboardingResponse in JSON string, error: {}", e.getMessage());
            }
        }
        return null;
    }

 
    private OnboardingRequest buildOnboardingRequest(OnboardingResponse onboarding) {
        MerchantDto merchant = merchantMapper.mapAdminDto(onboarding.getMerchant());
        MerchantUserDto user = merchantMapper.mapAdminDto(onboarding.getUser());
        if(null == user) {
            throw new ValidationException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, USER));
        }
        return OnboardingRequest.builder().merchant(merchant).user(user).bankAccounts(onboarding.getBankAccounts()).build();
    }

 
    public void  onboardAdminPortalMerchant(String mId){
        log.info("Processing merchant onboarding request for mid : {}",mId);
        MerchantResponse<MerchantOnboardingDto> adminMerchantInfoDto = adminDao.getMerchantsDetailsByMId(mId);
        MerchantOnboardingDto onboardingDto = adminMerchantInfoDto.getData().getFirst();
        OnboardingRequest onboardingRequest = merchantMapper.toOnboardingRequest(onboardingDto);
        onboardingRequest.getMerchant().setOnboardingTime(System.currentTimeMillis());
        onboardingMerchant(onboardingRequest);
        log.info("Completed merchant onboarding for mid : {}",mId);
    }
