        throwIfErrors();
        checkMerchantUserExistByUserName(userEntityMappingRequest.getUserName(), userEntityMappingRequest.getUserId());
        boolean isMerchantUserExist = false;
        if (isUserNamePresent) {
            isMerchantUserExist = adminDao.isMerchantUserExistWithRoles(userEntityMappingRequest.getUserName(), List.of(MerchantUserRoles.ADMIN.name(), MerchantUserRoles.SUPER_ADMIN.name()));
        } else if (isUserIdPresent) {
            isMerchantUserExist = adminDao.isMerchantUserExistWithRoles(UUID.fromString(userEntityMappingRequest.getUserId()), List.of(MerchantUserRoles.ADMIN.name(), MerchantUserRoles.SUPER_ADMIN.name()));
        }
        if (!isMerchantUserExist) {
            errorDtoList.add(ErrorDto.builder().errorCode(INVALID_ERROR_CODE).errorMessage(MessageFormat.format(INVALID_ERROR_MESSAGE, MerchantConstant.ROLE, "Reason : only ADMIN and SUPER_ADMIN are allowed")).build());
        }
        throwIfErrors();
    }


    public boolean isUserPresent(String userName) {
        if (isEmpty(userName)) {
            return false;
        } else return isNotContainsNull(userName);
    }


    private void checkMerchantUserExistByUserName(String userName, String userId) {
        boolean isExist = isUserPresent(userName) ? adminDao.isMerchantUserExist(userName,userName,userName) : adminDao.isMerchantUserExistByUserId(UUID.fromString(userId));
        if (!isExist) {
           errorDtoList.add(ErrorDto.builder().errorCode(NOT_FOUND_ERROR_CODE).errorMessage(MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, MerchantConstant.MERCHANT_USER)).build());
        }
        throwIfErrors();
    }

    private void validatedMId(MerchantEntityGroupRequest merchantEntityGroupRequest) {
        validateMappedEntityMIds(merchantEntityGroupRequest);
        validateMIds(merchantEntityGroupRequest);
    }

  
    private void isAlreadyMapped(UserEntityMappingRequest userEntityMappingRequest) {
        MerchantUser merchantUser = MerchantUser.builder().build();
        buildMerchantUser(merchantUser, userEntityMappingRequest);
        if(adminDao.isUserAlreadyMappedToEntity(merchantUser.getId(), userEntityMappingRequest.getEntityId())) {
            errorDtoList.add(ErrorDto.builder().errorCode(ALREADY_MAPPED_ERROR_CODE).errorMessage(MessageFormat.format(ALREADY_MAPPED_ERROR_MESSAGE, MerchantConstant.USER)).build());
        }
        throwIfErrors();
    }

    private void buildMerchantUser(MerchantUser merchantUser, UserEntityMappingRequest userEntityMappingRequest) {
        if( StringUtils.isEmpty(userEntityMappingRequest.getUserId())) {
            MerchantUserDto merchantUserDto = adminDao.getMerchantIdByUserName(userEntityMappingRequest.getUserName());
            merchantUser.setId(merchantUserDto.getId());
        } else {
            merchantUser.setId(UUID.fromString(userEntityMappingRequest.getUserId()));
        }
    }

    public void validateDuplicateItem(List<String> mIds) {
        if( mIds.size() != mIds.stream().distinct().count()) {
            errorDtoList.add(ErrorDto.builder().errorCode(INVALID_ERROR_CODE).errorMessage(MessageFormat.format(INVALID_ERROR_MESSAGE, MerchantConstant.MID, MerchantConstant.DUPLICATE_MID_FOUND)).build());
