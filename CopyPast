@Component
public class MasterHandlerFactory<T extends BaseMasterDto> {

    private final Map<String, BaseMasterService<T>> masterServiceMap;

    public MasterHandlerFactory(Map<String, BaseMasterService<T>> masterServiceMap) {
        this.masterServiceMap = masterServiceMap;
    }

    public BaseMasterService<T> getMasterService(String masterCode){
        BaseMasterService<T> masterService = masterServiceMap.get(masterCode+"Service");
        if(masterService == null){
            throw new AdminPortalException(ErrorConstants.GENERATION_ERROR_CODE, MessageFormat.format(ErrorConstants.GENERATION_ERROR_MESSAGE, masterCode));
        }
        return masterService;
    }

}
