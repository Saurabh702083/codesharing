@RestController
@RequestMapping("/master")
@RequiredArgsConstructor
public class MasterController {

    private final MasterService masterService;

    @PostMapping("/{masterCode}")
    public AdminPortalResponse<MasterResponse> create(@PathVariable String masterCode, @RequestBody MasterRequest masterRequest){
        masterRequest.setMasterCode(masterCode);
        return masterService.create(masterRequest);
    }

    @PostMapping("/approve/{masterCode}")
    public AdminPortalResponse<String> approve(@PathVariable String masterCode, @RequestBody MasterApproveRejectRequest masterApproveRejectRequest){
        return masterService.approveMaster(masterApproveRejectRequest, masterCode);
    }

    @PostMapping("/reject/{masterCode}")
    public AdminPortalResponse<String> reject(@PathVariable String masterCode, @RequestBody MasterApproveRejectRequest masterApproveRejectRequest){
        return masterService.rejectMaster(masterApproveRejectRequest, masterCode);
    }

    @PostMapping("/inactivate/{masterCode}")
    public AdminPortalResponse<String> inactivate (@PathVariable String masterCode, @RequestBody MasterInactivationRequest masterInactivationRequest){
        return masterService.inactivateMaster(masterInactivationRequest, masterCode);
    }

}
