import static com.epay.admin.portal.util.AdminPortalConstants.SUCCESS_RESPONSE_CODE;
import static com.epay.admin.portal.util.ErrorConstants.DUPLICATE_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.DUPLICATE_ERROR_MESSAGE;
import static com.epay.admin.portal.util.ErrorConstants.INVALID_STATUS_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_MESSAGE;

@Component
public class CityAreaPincodeHandler
        extends AbstractChildMasterHandler<CityAreaPincodeDto, CityAreaPincode> {

    private final CityAreaPincodeDao cityAreaPincodeDao;
    private final StateDao stateDao;
    private final CityAreaPincodeMapper cityAreaPincodeMapper;

    public CityAreaPincodeHandler(
            CityAreaPincodeDao cityAreaPincodeDao,
            StateDao stateDao,
            MasterWorkflowDao masterWorkflowDao,
            ObjectMapper objectMapper,
            CityAreaPincodeMapper cityAreaPincodeMapper) {
        super(masterWorkflowDao, objectMapper);
        this.cityAreaPincodeDao = cityAreaPincodeDao;
        this.stateDao = stateDao;
        this.cityAreaPincodeMapper = cityAreaPincodeMapper;
    }

    @Override
    public MasterType getMasterType() {
        return MasterType.CITY_AREA_PINCODE;
    }

    @Override
    protected MasterType getParentMasterType() {
        return MasterType.STATE;
    }

    @Override
    public Class<CityAreaPincodeDto> getDtoClass() {
        return CityAreaPincodeDto.class;
    }

    @Override
    protected void validateAndResolveParent(CityAreaPincodeDto dto) {
        log.info("Resolving parent State for stateName={}", dto.getStateName());
        State state = getStateByName(dto.getStateName());
        if (!MasterStatus.ACTIVE.matches(state.getStatus())) {
            throw new AdminPortalException(
                    INVALID_STATUS_ERROR_CODE,
                    MessageFormat.format(
                            "Parent State must be ACTIVE to add a city/area pin code. "
                                    + "stateName={0} currentStatus={1}",
                            dto.getStateName(),
                            state.getStatus()));
        }
    }

    @Override
    protected void validateChildCreate(CityAreaPincodeDto dto) {
        log.info(
                "Validating city/area pin code for stateName={} cityAreaName={} pinCode={}",
                dto.getStateName(),
                dto.getCityAreaName(),
                dto.getPinCode());
        State state = getStateByName(dto.getStateName());
        boolean duplicate = cityAreaPincodeDao.existsByStateIdAndCityAreaNameAndPinCode(
                state.getId(),
                dto.getCityAreaName(),
                dto.getPinCode());
        if (duplicate) {
            throw new AdminPortalException(
                    DUPLICATE_ERROR_CODE,
                    MessageFormat.format(
                            DUPLICATE_ERROR_MESSAGE,
                            "City/area and pin code",
                            dto.getCityAreaName() + ", " + dto.getPinCode()
                                    + " already mapped to stateName=" + dto.getStateName()));
        }
    }

    @Override
    public MasterWorkflow createMaster(CityAreaPincodeDto dto) {
        log.info(
                "Creating pending city/area pin code for stateName={} cityAreaName={} pinCode={}",
                dto.getStateName(),
                dto.getCityAreaName(),
                dto.getPinCode());
        String makerId = EPayIdentityUtil.getUserPrincipal().getUsername();
        State state = getStateByName(dto.getStateName());

        CityAreaPincode entity = cityAreaPincodeMapper.toEntity(dto, state.getId());
        entity.setStatus(MasterStatus.APPROVAL_PENDING.getValue());
        entity.setCreatedBy(makerId);

        CityAreaPincode saved = cityAreaPincodeDao.save(entity);
        MasterWorkflow workflow = MasterWorkflow.builder()
                .masterType(MasterType.CITY_AREA_PINCODE)
                .masterCode(saved.getPinCode())
                .recordId(saved.getId())
                .newValue(serializeEntity(saved, "city-area-pincode create payload"))
                .status(WorkflowStatus.PENDING)
                .actionType(ActionType.CREATE.name())
                .makerId(makerId)
                .build();

        MasterWorkflow savedWorkflow = masterWorkflowDao.save(workflow);
        log.info("CityAreaPincode workflow created workflowId={}", savedWorkflow.getId());
        return savedWorkflow;
    }

    @Override
    public AdminPortalResponse<?> search(JsonNode request, Pageable pageable) {
        log.info("Searching city/area pin code records pageable={}", pageable);
        CityAreaPinCodeSearchRequest searchRequest =
                objectMapper.convertValue(request, CityAreaPinCodeSearchRequest.class);
        Page<CityAreaPincode> page = cityAreaPincodeDao.findAll(
                CityAreaPincodeSpecification.build(searchRequest),
                pageable);
        return AdminPortalResponse.<CityAreaPincodeResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(page.getContent().stream().map(this::toResponse).toList())
                .count((long) page.getNumberOfElements())
                .total(page.getTotalElements())
                .build();
    }

    @Override
    public CityAreaPincode findEntityById(UUID id) {
        return cityAreaPincodeDao.findById(id).orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "CityAreaPincode with id=" + id)));
    }

    @Override
    public CityAreaPincode saveEntity(CityAreaPincode entity) {
        return cityAreaPincodeDao.save(entity);
    }

    @Override
    public String getEntityStatus(CityAreaPincode entity) {
        return entity.getStatus();
    }

    @Override
    public void setEntityStatus(CityAreaPincode entity, String status) {
        entity.setStatus(status);
    }

    @Override
    public String getEntityMasterCode(CityAreaPincode entity) {
        return entity.getPinCode();
    }

    private State getStateByName(String stateName) {
        return stateDao.findByStateName(stateName).orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "State with stateName=" + stateName)));
    }

    private CityAreaPincodeResponse toResponse(CityAreaPincode cityAreaPincode) {
        State state = stateDao.findById(cityAreaPincode.getStateId()).orElse(null);
        return cityAreaPincodeMapper.toResponse(cityAreaPincode, state);
    }
}
