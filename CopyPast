            throw new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Assign MIF steps"));
        }

        List<MIFJourneySteps> mifJourneySteps = assignMifSteps.stream()
                .map(step -> MIFJourneySteps.builder()
                        .merchantMifId(merchantMifId)
                        .journeyId(journeyId)
                        .stepNum(step.getStepNum())
                        .stepCode(step.getStepCode())
                        .status(StageStatus.NOT_STARTED)
                        .build())
                .toList();

        mifJourneyStepsRepository.saveAll(mifJourneySteps);
    }
