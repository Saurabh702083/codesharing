    private final MerchantInfoDao merchantInfoDao;
    private final AdminServicesClient adminServicesClient;
    private final MerchantUserValidator merchantUserValidator;


    public void validateMerchantAccountRequest(MerchantBankAccountRequest merchantBankAccountRequest) {
        logger.debug("Merchant bank account details validation start for mId: {}", merchantBankAccountRequest.getMId());
        errorDtoList = new ArrayList<>();
        validatedMandatoryFields(merchantBankAccountRequest);
        checkLeadingTrailingAndSingleSpace(merchantBankAccountRequest);
        validateFieldLength(merchantBankAccountRequest);
        validateFieldsValue(merchantBankAccountRequest);
        validateRequestValues(merchantBankAccountRequest);
        validateMId(merchantBankAccountRequest.getMId());
        validateAccountUniqueIdentifier(merchantBankAccountRequest);
        validateBankDetails(merchantBankAccountRequest);
        logger.debug("Merchant bank account details validation completed for mId: {}", merchantBankAccountRequest.getMId());
    }


    public void validateMerchantAccountUpdateRequest(MerchantBankAccountUpdateRequest merchantBankAccountUpdateRequest) {
        logger.debug("Merchant bank account details validation start for mId: {}", merchantBankAccountUpdateRequest.getMId());
        errorDtoList = new ArrayList<>();
        validatedMandatoryFields(merchantBankAccountUpdateRequest);
        checkLeadingTrailingAndSingleSpace(merchantBankAccountUpdateRequest);
        validateFieldLength(merchantBankAccountUpdateRequest);
        validateFieldsValue(merchantBankAccountUpdateRequest);
        validateMId(merchantBankAccountUpdateRequest.getMId());
        validateAccountUniqueIdentifier(merchantBankAccountUpdateRequest.getMId(), merchantBankAccountUpdateRequest.getAccountUniqueIdentifier());
        validatePrimaryForInActiveStatus(merchantBankAccountUpdateRequest);
        validateAccountUniqueIdentifierAndStatus(merchantBankAccountUpdateRequest.getMId(), merchantBankAccountUpdateRequest.getAccountUniqueIdentifier(), ACTIVE);
        logger.debug("Merchant bank account details validation completed for mId: {}", merchantBankAccountUpdateRequest.getMId());
