@Transactional
public AdminPortalResponse<String> rejectMaster(
        MasterApproveRejectRequest request,
        String masterCode) {

    MasterType master = MasterType.getMasterType(masterCode);

    BaseMasterService<BaseMasterDto> service =
            masterHandlerFactory.getMasterService(master.name());

    List<UUID> ids = request.getRecords()
            .stream()
