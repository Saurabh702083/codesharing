package com.epay.admin.portal.master.util.ENUM;

import com.epay.admin.portal.exceptions.AdminPortalException;
import com.epay.admin.portal.util.ErrorConstants;

import java.text.MessageFormat;
import java.util.Arrays;

import static com.epay.admin.portal.util.ErrorConstants.INVALID_ENUM_ERROR_MESSAGE;

public enum MasterType {
    // Standalone masters
    CONSTITUTION,
    NATURE_OF_BUSINESS,
    COUNTRY,

    // Child/Dependent masters
    COUNTRY_CURRENCY;

    public static MasterType getMasterType(String masterType) {
        return Arrays.stream(values())
                .filter(s -> s.name().equalsIgnoreCase(masterType))
                .findFirst()
                .orElseThrow(() -> new AdminPortalException(ErrorConstants.INVALID_ENUM_ERROR_CODE, MessageFormat.format(INVALID_ENUM_ERROR_MESSAGE, "masterType")));
    }
}


