        ValidationException exception = assertThrows(ValidationException.class, () -> merchantOnboardingValidator.validateMerchantOnBoardMIFId("2026021219015874AB"));
        assertEquals(exception.getErrorMessages().getFirst().getErrorCode(), "8002");
