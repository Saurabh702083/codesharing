    @PreAuthorize("hasAnyRole('BIZ_SUPPORT')")
    @PostMapping("/{MIFId}/{moduleCode}")
    @Operation(summary = "Update MIF based on moduleCode", description = "This API used to update particular MIF linked with user.")
    public AdminPortalResponse<String> updateMerchantMIF(@PathVariable("MIFId") String merchantMIFId, @PathVariable("moduleCode") String moduleCode, @RequestBody AdminMIFUpdateRequest adminMIFUpdateRequest) {
        logger.info("Update Merchant Onboarding merchantMIFId {} Form : adminMIFUpdateRequest {}", merchantMIFId, adminMIFUpdateRequest);
        return mifOnboardingService.updateAdminMerchantMIF(merchantMIFId, moduleCode, adminMIFUpdateRequest);
    }



    public AdminPortalResponse<String> updateAdminMerchantMIF(String merchantMIFId, String moduleCode, AdminMIFUpdateRequest adminMIFUpdateRequest) {
            merchantOnboardingValidator.validateAdminMerchantOnboardingRequest(adminMIFUpdateRequest, merchantMIFId ,moduleCode);
            logger.info("Admin merchant onboarding request validation successfully.");
            merchantOnboardingDao.updateMerchantMIFInfoWithoutDocument(adminMIFUpdateRequest);
            logger.debug("Returning AdminResponse with status code: {}", SUCCESS_RESPONSE_CODE);
            return AdminPortalResponse.<String>builder().status(SUCCESS_RESPONSE_CODE).data(List.of("Data Updated Successfully")).build();
    }



    public void validateAdminMerchantOnboardingRequest(AdminMIFUpdateRequest adminMIFUpdateRequest, String merchantMIFId,String moduleCode) {
        errorDtoList = new ArrayList<>();
        MIFModuleCode mifModuleCode = MIFModuleCode.getMIFModuleCode(moduleCode);
        if (MIFModuleCode.DOC_INFO.equals(mifModuleCode)) {
            throw new AdminPortalException(INVALID_ERROR_CODE_NO_REASON, java.text.MessageFormat.format(INVALID_ERROR_MESSAGE_NO_REASON, "MIF Module Code", moduleCode));
        }
        validateMerchantOnBoardMIFId(merchantMIFId);
        throwIfErrors();

        if (adminMIFUpdateRequest == null) {
            errorDtoList.add(ErrorDto.builder()
                    .errorCode(MANDATORY_ERROR_CODE)
                    .errorMessage(MessageFormat.format(MANDATORY_ERROR_MESSAGE, "Request body"))
                    .build());
            throwIfErrors();
            return;
        }

        validateAndAddError(adminMIFUpdateRequest.getBusinessDto(), BUSINESS_DTO);
        validateAndAddError(adminMIFUpdateRequest.getContactDto(), CONTACT_DTO);
        validateAndAddError(adminMIFUpdateRequest.getWebsiteDto(), WEB_SITE_DTO);
        validateAndAddError(adminMIFUpdateRequest.getBankTxnDto(), BANK_TXN_DTO);
        validateAndAddError(adminMIFUpdateRequest.getBankAccountInfoDto(), BANK_ACCOUNT_INFO_DTO);
        validateAndAddError(adminMIFUpdateRequest.getTifDto(), TIF_DTO);
        validateAndAddError(adminMIFUpdateRequest.getVsccDto(), VSCC_DTO);
        throwIfErrors();

        MIFOnboardingRequest mifOnboardingRequest = adminMIFUpdateRequest.toMIFOnboardingRequest();
        validateBusinessInfo(mifOnboardingRequest, merchantMIFId);
        validateContactInfo(mifOnboardingRequest, merchantMIFId);
        validateWebsiteInfo(mifOnboardingRequest, merchantMIFId);
        validateBankTxnInfo(mifOnboardingRequest, merchantMIFId);
        validateBankAccountInfo(mifOnboardingRequest, merchantMIFId);
        validateTifInfo(mifOnboardingRequest, merchantMIFId);
        validateVSCCInfo(mifOnboardingRequest, merchantMIFId);
        throwIfErrors();
    }






