public enum MasterType {
    // Standalone masters
    CONSTITUTION,
    NATURE_OF_BUSINESS,
    STATE,
    COUNTRY,

    // Child/Dependent masters
    COUNTRY_CURRENCY,
    CITY_AREA_PINCODE;

    public static MasterType getMasterType(String masterType) {
        return Arrays.stream(values())
                .filter(s -> s.name().equalsIgnoreCase(masterType))
                .findFirst()
                .orElseThrow(() -> new AdminPortalException(ErrorConstants.INVALID_ENUM_ERROR_CODE, MessageFormat.format(INVALID_ENUM_ERROR_MESSAGE, "masterType")));
    }
}
