package com.epay.admin.portal.validator;

import com.epay.admin.portal.master.dto.request.CityAreaPincodeDto;
import com.epay.admin.portal.master.dto.request.ConstitutionDTO;
import com.epay.admin.portal.master.dto.request.CountryCurrencyDTO;
import com.epay.admin.portal.master.dto.request.CountryDTO;
import com.epay.admin.portal.master.dto.request.MasterApprovalRequest;
import com.epay.admin.portal.master.dto.request.MasterInactivationRequest;
import com.epay.admin.portal.master.dto.request.NatureOfBusinessDto;
import com.epay.admin.portal.master.dto.request.StateDto;
import com.epay.admin.portal.master.util.ENUM.MasterType;
import com.sbi.epay.logging.utility.LoggerFactoryUtility;
import com.sbi.epay.logging.utility.LoggerUtility;
import org.springframework.stereotype.Component;

import java.util.ArrayList;
import java.util.HashSet;
import java.util.Set;
import java.util.UUID;

import static com.epay.admin.portal.util.AdminPortalConstants.ALPHA_ONLY_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.ALPHANUMERIC_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.COUNTRY_OR_STATE_NAME_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.GENERIC_TEXT_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.NAME_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.PINCODE_REGEX;
import static com.epay.admin.portal.util.AdminPortalConstants.REMARK_LENGTH;
import static com.epay.admin.portal.util.ErrorConstants.INVALID_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.INVALID_ERROR_MESSAGE;
import static com.epay.admin.portal.util.ErrorConstants.INCORRECT_FORMAT;

@Component
public class MasterRequestValidator extends BaseValidator {

    private static final int MASTER_NAME_MAX_LENGTH = 255;
    private static final int COUNTRY_CODE_MAX_LENGTH = 10;
    private static final int CURRENCY_CODE_MAX_LENGTH = 10;
    private static final int PIN_CODE_MAX_LENGTH = 20;

    private static final String CONSTITUTION_NAME = "constitutionName";
    private static final String COUNTRY_CODE = "countryCode";
    private static final String COUNTRY_NAME = "countryName";
    private static final String CURRENCY_CODE = "currencyCode";
    private static final String CURRENCY_NAME = "currencyName";
    private static final String STATE_NAME = "stateName";
    private static final String CITY_AREA_NAME = "cityAreaName";
    private static final String PIN_CODE = "pinCode";
    private static final String NATURE_OF_BUSINESS_NAME = "natureOfBusinessName";
    private static final String REQUEST = "request";
    private static final String RECORDS = "records";
    private static final String MASTER_IDS = "masterIds";
    private static final String MASTER_ID = "masterId";
    private static final String REMARK = "remark";
    private static final String DUPLICATE_VALUE = "Duplicate value provided";

    private final LoggerUtility logger = LoggerFactoryUtility.getLogger(this.getClass());

    public void validateCreateRequest(MasterType masterType, Object request) {
        logger.info("Validating master create request for masterType={}", masterType);
        errorDtoList = new ArrayList<>();
        checkMandatoryField(request, REQUEST);
        throwIfErrors();

        switch (masterType) {
            case CONSTITUTION -> validateConstitution((ConstitutionDTO) request);
            case COUNTRY -> validateCountry((CountryDTO) request);
            case COUNTRY_CURRENCY -> validateCountryCurrency((CountryCurrencyDTO) request);
            case STATE -> validateState((StateDto) request);
            case CITY_AREA_PINCODE -> validateCityAreaPincode((CityAreaPincodeDto) request);
            case NATURE_OF_BUSINESS -> validateNatureOfBusiness((NatureOfBusinessDto) request);
        }
    }

    public void validateInactivationRequest(MasterInactivationRequest request) {
        logger.info("Validating master inactivation request");
        errorDtoList = new ArrayList<>();
        checkMandatoryField(request, REQUEST);
        throwIfErrors();

        checkMandatoryField(request.getMasterIds(), MASTER_IDS);
        checkMandatoryField(request.getRemark(), REMARK);
        throwIfErrors();

        validateMasterIds(request.getMasterIds(), MASTER_IDS);
        validateLeadingTrailing(REMARK, request.getRemark());
        validateMaxLength(REMARK, request.getRemark(), REMARK_LENGTH);
    }

    public void validateApprovalRequest(MasterApprovalRequest request) {
        logger.info("Validating master approval request");
        validateApprovalOrRejectionRequest(request, false);
    }

    public void validateRejectionRequest(MasterApprovalRequest request) {
        logger.info("Validating master rejection request");
        validateApprovalOrRejectionRequest(request, true);
    }

    private void validateConstitution(ConstitutionDTO request) {
        validateMandatoryFields(CONSTITUTION_NAME, request.getConstitutionName());
        validateLeadingTrailing(CONSTITUTION_NAME, request.getConstitutionName());
        validateMaxLength(CONSTITUTION_NAME, request.getConstitutionName(), MASTER_NAME_MAX_LENGTH);
        validateFormat(CONSTITUTION_NAME, request.getConstitutionName(), GENERIC_TEXT_REGEX);
    }

    private void validateCountry(CountryDTO request) {
        validateMandatoryFields(
                COUNTRY_CODE, request.getCountryCode(),
                COUNTRY_NAME, request.getCountryName());
        validateLeadingTrailing(
                COUNTRY_CODE, request.getCountryCode(),
                COUNTRY_NAME, request.getCountryName());
        validateMaxLength(
                COUNTRY_CODE, request.getCountryCode(), COUNTRY_CODE_MAX_LENGTH,
                COUNTRY_NAME, request.getCountryName(), MASTER_NAME_MAX_LENGTH);
        validateFormat(COUNTRY_CODE, request.getCountryCode(), ALPHANUMERIC_REGEX);
        validateFormat(COUNTRY_NAME, request.getCountryName(), COUNTRY_OR_STATE_NAME_REGEX);
    }

    private void validateCountryCurrency(CountryCurrencyDTO request) {
        validateMandatoryFields(
                COUNTRY_CODE, request.getCountryCode(),
                CURRENCY_CODE, request.getCurrencyCode(),
                CURRENCY_NAME, request.getCurrencyName());
        validateLeadingTrailing(
                COUNTRY_CODE, request.getCountryCode(),
                CURRENCY_CODE, request.getCurrencyCode(),
                CURRENCY_NAME, request.getCurrencyName());
        validateMaxLength(
                COUNTRY_CODE, request.getCountryCode(), COUNTRY_CODE_MAX_LENGTH,
                CURRENCY_CODE, request.getCurrencyCode(), CURRENCY_CODE_MAX_LENGTH,
                CURRENCY_NAME, request.getCurrencyName(), MASTER_NAME_MAX_LENGTH);
        validateFormat(COUNTRY_CODE, request.getCountryCode(), ALPHANUMERIC_REGEX);
        validateFormat(CURRENCY_CODE, request.getCurrencyCode(), ALPHA_ONLY_REGEX);
        validateFormat(CURRENCY_NAME, request.getCurrencyName(), NAME_REGEX);
    }

    private void validateState(StateDto request) {
        validateMandatoryFields(STATE_NAME, request.getStateName());
        validateLeadingTrailing(STATE_NAME, request.getStateName());
        validateMaxLength(STATE_NAME, request.getStateName(), MASTER_NAME_MAX_LENGTH);
        validateFormat(STATE_NAME, request.getStateName(), COUNTRY_OR_STATE_NAME_REGEX);
    }

    private void validateCityAreaPincode(CityAreaPincodeDto request) {
        validateMandatoryFields(
                CITY_AREA_NAME, request.getCityAreaName(),
                STATE_NAME, request.getStateName(),
                PIN_CODE, request.getPinCode());
        validateLeadingTrailing(
                CITY_AREA_NAME, request.getCityAreaName(),
                STATE_NAME, request.getStateName(),
                PIN_CODE, request.getPinCode());
        validateMaxLength(
                CITY_AREA_NAME, request.getCityAreaName(), MASTER_NAME_MAX_LENGTH,
                STATE_NAME, request.getStateName(), MASTER_NAME_MAX_LENGTH,
                PIN_CODE, request.getPinCode(), PIN_CODE_MAX_LENGTH);
        validateFormat(CITY_AREA_NAME, request.getCityAreaName(), GENERIC_TEXT_REGEX);
        validateFormat(STATE_NAME, request.getStateName(), COUNTRY_OR_STATE_NAME_REGEX);
        validateFormat(PIN_CODE, request.getPinCode(), PINCODE_REGEX);
    }

    private void validateNatureOfBusiness(NatureOfBusinessDto request) {
        validateMandatoryFields(NATURE_OF_BUSINESS_NAME, request.getNatureOfBusinessName());
        validateLeadingTrailing(NATURE_OF_BUSINESS_NAME, request.getNatureOfBusinessName());
        validateMaxLength(NATURE_OF_BUSINESS_NAME, request.getNatureOfBusinessName(), MASTER_NAME_MAX_LENGTH);
        validateFormat(NATURE_OF_BUSINESS_NAME, request.getNatureOfBusinessName(), GENERIC_TEXT_REGEX);
    }

    private void validateMandatoryFields(Object... fields) {
        for (int index = 0; index < fields.length; index += 2) {
            checkMandatoryField((String) fields[index + 1], (String) fields[index]);
        }
        throwIfErrors();
    }

    private void validateLeadingTrailing(Object... fields) {
        for (int index = 0; index < fields.length; index += 2) {
            checkForLeadingTrailingAndSingleSpace((String) fields[index + 1], (String) fields[index]);
        }
        throwIfErrors();
    }

    private void validateMaxLength(Object... fields) {
        for (int index = 0; index < fields.length; index += 3) {
            validateFieldLength((String) fields[index + 1], (int) fields[index + 2], (String) fields[index]);
        }
        throwIfErrors();
    }

    private void validateFormat(String fieldName, String value, String regex) {
        validateFieldWithRegexAndEmpty(value, regex, fieldName, INCORRECT_FORMAT);
        throwIfErrors();
    }

    private void validateApprovalOrRejectionRequest(MasterApprovalRequest request, boolean remarkRequired) {
        errorDtoList = new ArrayList<>();
        checkMandatoryField(request, REQUEST);
        throwIfErrors();

        checkMandatoryField(request.getRecords(), RECORDS);
        throwIfErrors();

        Set<UUID> uniqueMasterIds = new HashSet<>();
        for (MasterApprovalRequest.ApprovalItem record : request.getRecords()) {
            checkMandatoryField(record, RECORDS);
            if (record == null) {
                continue;
            }
            checkMandatoryField(record.getMasterId(), MASTER_ID);
            if (remarkRequired) {
                checkMandatoryField(record.getRemark(), REMARK);
            }
        }
        throwIfErrors();

        for (MasterApprovalRequest.ApprovalItem record : request.getRecords()) {
            if (!uniqueMasterIds.add(record.getMasterId())) {
                addError(INVALID_ERROR_CODE, INVALID_ERROR_MESSAGE, (Object) MASTER_ID, DUPLICATE_VALUE);
            }
            if (record.getRemark() != null) {
                checkForLeadingTrailingAndSingleSpace(record.getRemark(), REMARK);
                validateFieldLength(record.getRemark(), REMARK_LENGTH, REMARK);
            }
        }
        throwIfErrors();
    }

    private void validateMasterIds(Iterable<UUID> masterIds, String fieldName) {
        Set<UUID> uniqueMasterIds = new HashSet<>();
        for (UUID masterId : masterIds) {
            checkMandatoryField(masterId, MASTER_ID);
            if (masterId != null && !uniqueMasterIds.add(masterId)) {
                addError(INVALID_ERROR_CODE, INVALID_ERROR_MESSAGE, (Object) fieldName, DUPLICATE_VALUE);
            }
        }
        throwIfErrors();
    }
}
