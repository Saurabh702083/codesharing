import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_CODE;
import static com.epay.admin.portal.util.ErrorConstants.NOT_FOUND_ERROR_MESSAGE;

@Component
public class StateHandler extends AbstractMasterHandler<StateDto, State> {

    private final StateDao stateDao;
    private final CityAreaPincodeDao cityAreaPincodeDao;
    private final StateMapper stateMapper;

    public StateHandler(StateDao stateDao,
                        CityAreaPincodeDao cityAreaPincodeDao,
                        MasterWorkflowDao masterWorkflowDao,
                        ObjectMapper objectMapper,
                        StateMapper stateMapper) {
        super(masterWorkflowDao, objectMapper);
        this.stateDao = stateDao;
        this.cityAreaPincodeDao = cityAreaPincodeDao;
        this.stateMapper = stateMapper;
    }

    @Override
    public MasterType getMasterType() {
        return MasterType.STATE;
    }

    @Override
    public Class<StateDto> getDtoClass() {
        return StateDto.class;
    }

    @Override
    public void validateCreate(StateDto dto) {
        log.info("Validating state create for stateName={}", dto.getStateName());
        if (stateDao.existsByStateName(dto.getStateName())) {
            throw new AdminPortalException(
                    DUPLICATE_ERROR_CODE,
                    MessageFormat.format(DUPLICATE_ERROR_MESSAGE, "State name", dto.getStateName()));
        }
    }

    @Override
    public MasterWorkflow createMaster(StateDto dto) {
        log.info("Creating pending state for stateName={}", dto.getStateName());
        String makerId = EPayIdentityUtil.getUserPrincipal().getUsername();

        State entity = stateMapper.toEntity(dto);
        entity.setStateCode(MasterUtil.generateMasterCode(dto.getStateName(), MasterType.STATE));
        entity.setStatus(MasterStatus.APPROVAL_PENDING.getValue());
        entity.setCreatedBy(makerId);

        State saved = stateDao.save(entity);

        MasterWorkflow workflow = MasterWorkflow.builder()
                .masterType(MasterType.STATE)
                .masterCode(saved.getStateCode())
                .recordId(saved.getId())
                .newValue(serializeEntity(saved, "state create payload"))
                .status(WorkflowStatus.PENDING)
                .actionType(ActionType.CREATE.name())
                .makerId(makerId)
                .build();

        MasterWorkflow savedWorkflow = masterWorkflowDao.save(workflow);
        log.info("State workflow created workflowId={}", savedWorkflow.getId());
        return savedWorkflow;
    }

    @Override
    public AdminPortalResponse<?> search(JsonNode request, Pageable pageable) {
        log.info("Searching state records pageable={}", pageable);
        StateSearchRequest searchRequest = objectMapper.convertValue(request, StateSearchRequest.class);
        Page<State> page = stateDao.findAll(StateSpecification.build(searchRequest), pageable);
        return AdminPortalResponse.<StateResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(page.getContent().stream().map(stateMapper::toResponse).toList())
                .count((long) page.getNumberOfElements())
                .total(page.getTotalElements())
                .build();
    }

    @Override
    public State findEntityById(UUID id) {
        return stateDao.findById(id)
                .orElseThrow(() -> new AdminPortalException(
                        NOT_FOUND_ERROR_CODE,
                        MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "State with id=" + id)));
    }

    @Override
    public boolean hasActiveChildren(UUID stateId) {
        boolean hasActiveChildren = cityAreaPincodeDao.existsByStateIdAndStatus(
                stateId,
                MasterStatus.ACTIVE.getValue());
        boolean hasPendingChildren = cityAreaPincodeDao.existsByStateIdAndStatus(
                stateId,
                MasterStatus.APPROVAL_PENDING.getValue());
        log.info(
                "State id={} hasActiveCityAreaPincodes={} hasPendingCityAreaPincodes={}",
                stateId,
                hasActiveChildren,
                hasPendingChildren);
        return hasActiveChildren || hasPendingChildren;
    }

    @Override
    public State saveEntity(State state) {
        return stateDao.save(state);
    }

    @Override
    public String getEntityStatus(State state) {
        return state.getStatus();
    }

    @Override
    public void setEntityStatus(State state, String status) {
        state.setStatus(status);
    }

    @Override
    public String getEntityMasterCode(State state) {
        return state.getStateCode();
    }
}
