    }


    private void validateFieldWithRegex(UserEntityMappingRequest userEntityMappingRequest) {
        validateFieldWithRegex(userEntityMappingRequest.getEntityId(), MerchantConstant.ALLOWED_ALPHA_NUMERIC_REGEX, MerchantConstant.ENTITY_ID, INCORRECT_FORMAT);
        if (!isEmpty(userEntityMappingRequest.getUserName()) && isNotContainsNull(userEntityMappingRequest.getUserName())) {
            validateFieldWithRegex(userEntityMappingRequest.getUserName(), MerchantConstant.USER_NAME_REGEX, MerchantConstant.USER_NAME, INCORRECT_FORMAT);
        }
        if (!isEmpty(userEntityMappingRequest.getUserId()) && isNotContainsNull(userEntityMappingRequest.getUserId())) {
            validateFieldWithRegex(userEntityMappingRequest.getUserId(), MerchantConstant.UUID_FORMAT_REGEX, MerchantConstant.USER_ID, INCORRECT_FORMAT);
        }
        throwIfErrors();
    }

  
    private void validateMandatory(MerchantEntityGroupRequest merchantEntityGroupRequest) {
        checkMandatoryField(merchantEntityGroupRequest.getEntityId(), MerchantConstant.ENTITY_ID);
        checkMandatoryCollection(merchantEntityGroupRequest.getMIds(), MerchantConstant.MID_MAPPING_LIST);
        throwIfErrors();
        merchantEntityGroupRequest.getMIds()
                .forEach(mId -> checkMandatoryField(mId, MerchantConstant.MID));
