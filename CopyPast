package com.epay.admin.portal.master.service;


import com.epay.admin.portal.exceptions.AdminPortalException;
import com.epay.admin.portal.master.dao.MasterWorkflowDao;
import com.epay.admin.portal.master.dto.request.MasterApprovalRequest;
import com.epay.admin.portal.master.dto.request.MasterInactivationRequest;
import com.epay.admin.portal.master.dto.response.BulkUploadResponse;
import com.epay.admin.portal.master.dto.response.MasterResponse;
import com.epay.admin.portal.master.entity.MasterWorkflow;
import com.epay.admin.portal.master.factory.MasterHandlerFactory;
import com.epay.admin.portal.master.handler.AbstractMasterHandler;
import com.epay.admin.portal.master.handler.MasterHandler;
import com.epay.admin.portal.master.util.ENUM.MasterType;
import com.epay.admin.portal.master.util.ENUM.WorkflowStatus;
import com.epay.admin.portal.model.response.AdminPortalResponse;

import com.epay.admin.portal.util.EPayIdentityUtil;
import com.epay.admin.portal.validator.MasterRequestValidator;
import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.sbi.epay.logging.utility.LoggerFactoryUtility;
import com.sbi.epay.logging.utility.LoggerUtility;
import lombok.RequiredArgsConstructor;
import org.springframework.data.domain.Pageable;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.text.MessageFormat;
import java.util.List;
import java.util.UUID;

import static com.epay.admin.portal.util.AdminPortalConstants.SUCCESS_RESPONSE_CODE;
import static com.epay.admin.portal.util.ErrorConstants.*;


@Service
@RequiredArgsConstructor
public class AdminMasterService {

    private final MasterWorkflowDao masterWorkflowDao;
    private final MasterHandlerFactory handlerFactory;
    private final MasterBulkUploadService masterBulkUploadService;
    private final MasterRequestValidator masterRequestValidator;
    private final ObjectMapper objectMapper;
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());

    // ─────────────────────────────────────────────────────────────────────────
    // MAKER: Submit Create
    // New entity → APPROVAL_PENDING, Workflow → PENDING
    // ─────────────────────────────────────────────────────────────────────────

    @Transactional
    public AdminPortalResponse<MasterResponse> submitCreate(String masterType, JsonNode request) {
        MasterType master = MasterType.getMasterType(masterType);
        log.info("Submitting create for masterType={}", master);
        MasterHandler<?, ?> handler = handlerFactory.getHandler(master);
        MasterWorkflow workflow = validateAndCreate(handler, request);
        log.info("Create workflow submitted masterType={} workflowId={}", master, workflow.getId());
        return buildMasterResponse(List.of(buildWorkflowResponse("Request submitted successfully", workflow)));
    }

    // ─────────────────────────────────────────────────────────────────────────
    // MAKER: Submit Inactivation
    // Entity ACTIVE → INACTIVATION_PENDING, Workflow → INACTIVATION_PENDING
    // ─────────────────────────────────────────────────────────────────────────

    @Transactional
    public AdminPortalResponse<MasterResponse> submitInactivation(String masterType,
                                                                  MasterInactivationRequest request) {
        MasterType master = MasterType.getMasterType(masterType);
        masterRequestValidator.validateInactivationRequest(request);
        log.info("Submitting inactivation for masterType={} recordCount={}",
                master, request.getMasterIds().size());
        AbstractMasterHandler<?, ?> handler = handlerFactory.getAbstractHandler(master);
        List<MasterResponse> responses = request.getMasterIds().stream()
                .map(recordId -> buildWorkflowResponse(
                        "Inactivation submitted successfully",
                        handler.submitInactivation(recordId, request.getRemark())))
                .toList();
        return buildMasterResponse(responses);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CHECKER: Approve
    // APPROVAL_PENDING     → entity ACTIVE,    workflow APPROVED
    // INACTIVATION_PENDING → entity INACTIVE,  workflow APPROVED
    // ─────────────────────────────────────────────────────────────────────────

    @Transactional
    public AdminPortalResponse<String> approve(String masterType, MasterApprovalRequest request) {
        MasterType master = MasterType.getMasterType(masterType);
        masterRequestValidator.validateApprovalRequest(request);
        log.info("Approving records for masterType={} count={}", master, request.getRecords().size());
        AbstractMasterHandler<?, ?> handler = handlerFactory.getAbstractHandler(master);
        List<String> responses = request.getRecords().stream()
                .map(record -> processApprove(master, handler, record))
                .toList();
        return buildStringResponse(responses);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // CHECKER: Reject
    // APPROVAL_PENDING     → entity REJECTED, workflow REJECTED
    // INACTIVATION_PENDING → entity ACTIVE,   workflow REJECTED (rollback)
    // ─────────────────────────────────────────────────────────────────────────

    @Transactional
    public AdminPortalResponse<String> reject(String masterType, MasterApprovalRequest request) {
        MasterType master = MasterType.getMasterType(masterType);
        masterRequestValidator.validateRejectionRequest(request);
        log.info("Rejecting records for masterType={} count={}", master, request.getRecords().size());
        AbstractMasterHandler<?, ?> handler = handlerFactory.getAbstractHandler(master);
        List<String> responses = request.getRecords().stream()
                .map(record -> processReject(master, handler, record))
                .toList();
        return buildStringResponse(responses);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BOTH: Search
    // ─────────────────────────────────────────────────────────────────────────

    public AdminPortalResponse<?> search(String masterType, JsonNode request, Pageable pageable) {
        MasterType master = MasterType.getMasterType(masterType);
        log.info("Searching records for masterType={}", master);
        return handlerFactory.getHandler(master).search(request, pageable);
    }

    // ─────────────────────────────────────────────────────────────────────────
    // MAKER: Bulk Upload
    // ─────────────────────────────────────────────────────────────────────────

    public AdminPortalResponse<BulkUploadResponse> bulkUpload(String masterType,
                                                              MultipartFile file) throws IOException {
        log.info("Bulk upload for masterType={} fileName={}", masterType, file.getOriginalFilename());
        BulkUploadResponse response = masterBulkUploadService.bulkUpload(masterType, file);
        return AdminPortalResponse.<BulkUploadResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(List.of(response))
                .count(1L).total(1L)
                .build();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Private helpers
    // ─────────────────────────────────────────────────────────────────────────

    private <T> MasterWorkflow validateAndCreate(MasterHandler<T, ?> handler, JsonNode request) {
        T dto = deserialize(handler.getDtoClass(), request);
        masterRequestValidator.validateCreateRequest(handler.getMasterType(), dto);
        handler.validateCreate(dto);
        return handler.createMaster(dto);
    }

    private <T> T deserialize(Class<T> clazz, JsonNode node) {
        try {
            return objectMapper.treeToValue(node, clazz);
        } catch (JsonProcessingException | IllegalArgumentException ex) {
            log.error("Failed to deserialize request to {}", clazz.getSimpleName(), ex);
            throw new AdminPortalException(JSON_ERROR_CODE,
                    MessageFormat.format(JSON_ERROR_MESSAGE, clazz.getSimpleName()));
        }
    }

    private String processApprove(MasterType masterType,
                                  AbstractMasterHandler<?, ?> handler,
                                  MasterApprovalRequest.ApprovalItem record) {
        log.info("Processing approve masterType={} masterId={}", masterType, record.getMasterId());
        MasterWorkflow workflow = findPendingWorkflow(masterType, record.getMasterId());
        handler.validateAndApplyApproved(workflow);          // transitions entity + workflow status
        workflow.setRemark(record.getRemark());
        workflow.setCheckerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        masterWorkflowDao.save(workflow);
        log.info("Approved masterId={} masterType={}", record.getMasterId(), masterType);
        return "Approved masterId=" + record.getMasterId();
    }

    private String processReject(MasterType masterType,
                                 AbstractMasterHandler<?, ?> handler,
                                 MasterApprovalRequest.ApprovalItem record) {
        log.info("Processing reject masterType={} masterId={}", masterType, record.getMasterId());
        MasterWorkflow workflow = findPendingWorkflow(masterType, record.getMasterId());
        handler.validateAndApplyRejected(workflow, record.getRemark()); // transitions entity + workflow status
        workflow.setRemark(record.getRemark());
        workflow.setCheckerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        masterWorkflowDao.save(workflow);
        log.info("Rejected masterId={} masterType={}", record.getMasterId(), masterType);
        return "Rejected masterId=" + record.getMasterId();
    }

    private MasterWorkflow findPendingWorkflow(MasterType masterType, UUID recordId) {
        return masterWorkflowDao.findLatestByMasterTypeAndRecordIdAndStatuses(
                        masterType, recordId,
                        List.of(WorkflowStatus.PENDING, WorkflowStatus.INACTIVATION_PENDING))
                .orElseThrow(() -> new AdminPortalException(NOT_FOUND_ERROR_CODE,
                        MessageFormat.format(NOT_FOUND_ERROR_MESSAGE,
                                "Pending workflow for masterId=" + recordId)));
    }

    private MasterResponse buildWorkflowResponse(String message, MasterWorkflow workflow) {
        return MasterResponse.builder()
                .message(message)
                .status(workflow.getStatus().name())
                .masterRecordId(workflow.getRecordId())
                .masterCode(workflow.getMasterCode())
                .build();
    }

    private AdminPortalResponse<MasterResponse> buildMasterResponse(List<MasterResponse> data) {
        return AdminPortalResponse.<MasterResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(data)
                .count((long) data.size())
                .total((long) data.size())
                .build();
    }

    private AdminPortalResponse<String> buildStringResponse(List<String> data) {
        return AdminPortalResponse.<String>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(data)
                .count((long) data.size())
                .total((long) data.size())
                .build();
