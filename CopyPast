        if (!found) {
            errorDtoList.add(ErrorDto.builder().errorCode(USER_ALREADY_EXIST_ERROR_CODE_UPDATE).errorMessage(MessageFormat.format(USER_ALREADY_EXIST_ERROR_MESSAGE_UPDATE, mobilePhone, email)).build());
