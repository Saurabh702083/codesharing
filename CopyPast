-----Validation

@Override
public void validateForApprove(
        List<CountryDto> masters){

    List<UUID> invalidIds =
            masters.stream()

            .filter(master ->

                    !MasterStatus.PENDING_FOR_APPROVAL
                            .getValue()
                            .equals(master.getStatus())

                    &&

                    !MasterStatus.PENDING_FOR_INACTIVATION
                            .getValue()
                            .equals(master.getStatus()))

            .map(CountryDto::getId)

            .toList();

    if(!invalidIds.isEmpty()){

        throw new AdminPortalException(

                VALIDATION_ERROR_CODE,

                "Following records are not pending : "
                        + invalidIds

        );

    }

}


@Override
public void validateForInactivation(
        List<CountryDto> masters){

    List<UUID> invalidIds =
            masters.stream()

            .filter(master ->

                    !MasterStatus.ACTIVE
                            .getValue()
                            .equals(master.getStatus()))

            .map(CountryDto::getId)

            .toList();

    if(!invalidIds.isEmpty()){

        throw new AdminPortalException(

                VALIDATION_ERROR_CODE,

                "Following records are not ACTIVE : "
                        + invalidIds

        );

    }

}