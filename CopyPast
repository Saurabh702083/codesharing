    private void validateFieldsValue(MerchantEntityGroupRequest merchantEntityGroupRequest) {
        validateFieldWithRegex(merchantEntityGroupRequest.getEntityId(), MerchantConstant.ALLOWED_ALPHA_NUMERIC_REGEX, MerchantConstant.ENTITY_ID, INCORRECT_FORMAT);
        merchantEntityGroupRequest.getMIds()
                .forEach(mid -> {
