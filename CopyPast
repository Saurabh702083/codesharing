package com.epay.admin.portal.master.specification;

import com.epay.admin.portal.master.dto.request.NatureOfBusinessSearchRequest;
import com.epay.admin.portal.master.entity.NatureOfBusiness;
import org.apache.commons.lang3.StringUtils;
import org.springframework.data.jpa.domain.Specification;

public class NatureOfBusinessSpecification {

    private NatureOfBusinessSpecification() {}

    public static Specification<NatureOfBusiness> build(NatureOfBusinessSearchRequest req) {
        if (req == null) return Specification.where(null);
        return Specification
                .where(hasNatureOfBusinessName(req.getNatureOfBusinessName()))
                .and(hasStatus(req.getStatus()))
                .and(hasUpdatedAtBetween(req.getFromDate(), req.getToDate()));
    }

    private static Specification<NatureOfBusiness> hasNatureOfBusinessName(String name) {
        return (root, query, cb) -> StringUtils.isBlank(name) ? cb.conjunction()
                : cb.like(cb.lower(root.get("natureOfBusinessName")), "%" + name.toLowerCase() + "%");
    }

    private static Specification<NatureOfBusiness> hasStatus(String status) {
        return (root, query, cb) -> StringUtils.isBlank(status) ? cb.conjunction()
                : cb.equal(cb.lower(root.get("status")), status.toLowerCase());
    }

    private static Specification<NatureOfBusiness> hasUpdatedAtBetween(Long from, Long to) {
        return (root, query, cb) -> {
            if (from == null && to == null) return cb.conjunction();
            if (from != null && to != null) return cb.between(root.get("updatedAt"), from, to);
            if (from != null) return cb.greaterThanOrEqualTo(root.get("updatedAt"), from);
            return cb.lessThanOrEqualTo(root.get("updatedAt"), to);
        };
    }
}
