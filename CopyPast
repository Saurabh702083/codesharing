    public void validateBranchValidationRequest(BranchValidationRequest branchValidationRequest) {
        logger.info("Validating branch validation request");
        errorDtoList = new ArrayList<>();
        validateRole();
        validateBranchLookupMandatoryFields(branchValidationRequest);
        validateBranchFieldValues(branchValidationRequest);
        throwIfErrors();
    }

    private void validateBranchLookupMandatoryFields(BranchValidationRequest branchValidationRequest) {
        checkMandatoryField(branchValidationRequest.getBranchCode(), BRANCH_CODE);
        if (branchValidationRequest.getBranchName() != null && StringUtils.isBlank(branchValidationRequest.getBranchName())) {
            addError(BRANCH_NAME, MANDATORY_ERROR_CODE, MANDATORY_ERROR_MESSAGE);
        }
        throwIfErrors();
    }

    private void validateBranchFieldValues(BranchValidationRequest branchValidationRequest) {
        if (branchValidationRequest.getBranchCode() != null && branchValidationRequest.getBranchCode() <= 0) {
            addError(INVALID_ERROR_CODE, INVALID_ERROR_MESSAGE, BRANCH_CODE, "Value should be greater than 0");
        }

        if (StringUtils.isNotBlank(branchValidationRequest.getBranchName())) {
            checkForLeadingTrailingAndSingleSpace(branchValidationRequest.getBranchName(), BRANCH_NAME);
            validateFieldLength(branchValidationRequest.getBranchName(), BRANCH_NAME_LENGTH, BRANCH_NAME);
            validateFieldWithRegexAndEmpty(branchValidationRequest.getBranchName(), MIF_BRANCH_NAME_REGEX, BRANCH_NAME, INCORRECT_FORMAT);
        }
        throwIfErrors();
    }
