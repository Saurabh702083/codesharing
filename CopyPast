public ReportingResponse<SettlementRecordResponse> getSettlementStatusRecords(SettlementStatusSearchRequest settlementSearchRequest, Pageable pageable) {
        String mId = settlementSearchRequest.getMerchantId();
        logger.info("Settlement status report request for MID: {}, payload: {}", mId, settlementSearchRequest);
       // settlementStatusReportValidator.validateRequest(settlementSearchRequest);
        Page<MerchantOrderPaymentTxn> paymentPage = dao.searchSettlementRecords(mId, settlementSearchRequest, pageable);
        List<MerchantOrderPaymentTxn> payments = paymentPage.getContent();
        if (payments.isEmpty()) {
            return ReportingResponse.<SettlementRecordResponse>builder().status(RESPONSE_SUCCESS).data(Collections.emptyList()).count(0L).total(paymentPage.getTotalElements()).build();
        }
        List<String> sbiOrderIds = payments.stream().map(MerchantOrderPaymentTxn::getSbiOrderRefNumber).distinct().collect(Collectors.toList());
        List<MerchantOrderTxn> orders = dao.findOrdersForPayments(mId, sbiOrderIds);
        boolean includeSettlementFields = settlementSearchRequest.getSettlementStatus() != null;
        List<MerchantTxnPayout> payouts = Collections.emptyList();
        if (includeSettlementFields) {
            List<String> atrnNumbers = payments.stream().map(MerchantOrderPaymentTxn::getAtrnNum).distinct().collect(Collectors.toList());
            payouts = dao.findPayoutsForAtrns(mId, atrnNumbers);
        }
        List<SettlementRecordResponse> responseList = mapper.mapToResponse(payments, orders, payouts, includeSettlementFields);
        return ReportingResponse.<SettlementRecordResponse>builder().status(RESPONSE_SUCCESS).data(responseList).count((long) responseList.size()).total(paymentPage.getTotalElements()).build();
    }
