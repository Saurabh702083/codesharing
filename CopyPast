    }


    private void validateFieldLength(UserEntityMappingRequest userEntityMappingRequest) {
        if (!isEmpty(userEntityMappingRequest.getUserName()) && isNotContainsNull(userEntityMappingRequest.getUserName())) {
            validateFieldLength(userEntityMappingRequest.getUserName(), MerchantConstant.MAX_USER_NAME_LENGTH, MerchantConstant.USER_NAME);
        }
        if (!isEmpty(userEntityMappingRequest.getUserId()) && isNotContainsNull(userEntityMappingRequest.getUserId())) {
            validateFixedFieldLength(String.valueOf(userEntityMappingRequest.getUserId()), MerchantConstant.UUID_LENGTH, MerchantConstant.USER_ID);
