    private void validatedMandatoryFields(MerchantBankAccountRequest merchantBankAccountRequest) {
        checkMandatoryField(merchantBankAccountRequest.getBankName(), MerchantConstant.BANK_NAME);
        checkMandatoryField(merchantBankAccountRequest.getBranchName(), MerchantConstant.BRANCH_NAME);
        checkMandatoryField(merchantBankAccountRequest.getIfscCode(), MerchantConstant.IFSC_CODE);
        checkMandatoryField(merchantBankAccountRequest.getAccountType(), MerchantConstant.ACCOUNT_TYPE);
        checkMandatoryField(merchantBankAccountRequest.getAccountNumber(), MerchantConstant.ACCOUNT_NUMBER);
        checkMandatoryField(merchantBankAccountRequest.getAccountHolderName(), MerchantConstant.ACCOUNT_HOLDER_NAME);
