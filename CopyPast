    }


    private void checkLeadingTrailingAndSingleSpace(MerchantEntityGroupRequest merchantEntityGroupRequest) {
        checkForLeadingTrailingAndSingleSpace(merchantEntityGroupRequest.getEntityId(), MerchantConstant.ENTITY_ID);
        merchantEntityGroupRequest.getMIds()
                        .forEach(mid -> {
                            checkForLeadingTrailingAndSingleSpace(mid, MerchantConstant.MID);
