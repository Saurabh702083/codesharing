@Service
@RequiredArgsConstructor
public class MasterService {

    private final MasterHandlerFactory<BaseMasterDto> masterHandlerFactory;
    private final MasterWorkFlowService masterWorkFlowService;

    public AdminPortalResponse<MasterResponse> create(MasterRequest masterRequest) {
        BaseMasterService<BaseMasterDto> masterService = masterHandlerFactory.getMasterService(masterRequest.getMasterCode());
        BaseMasterDto masterDto = masterService.mapToMasterDto(masterRequest);
        masterService.validateCreate(masterDto);
        masterDto = masterService.create(masterDto);
        MasterWorkFlowDto masterWorkFlowDto = masterService.mapToMasterWorkFlowDto(masterDto);
        masterWorkFlowService.save(masterWorkFlowDto, WorkflowOperation.CREATE);
        return masterService.mapToResponse(masterDto);
    }

    @Transactional
    public AdminPortalResponse<String> approveMaster(MasterApproveRejectRequest request, String masterCode) {
        MasterType master = MasterType.getMasterType(masterCode);
        BaseMasterService<BaseMasterDto> service = masterHandlerFactory.getMasterService(master.name());
        List<UUID> ids = request.getRecords().stream().map(MasterApproveRejectRequest.RecordItem::getMasterId).toList();
        List<BaseMasterDto> masters = service.findByIds(ids);
//        service.validateForApprove(masters);
        service.approve(ids);
        request.getRecords().forEach(record -> masterWorkFlowService.approveWorkFlow(master, record));
        return AdminPortalResponse.<String>builder().status(SUCCESS_RESPONSE_CODE).data(List.of("Masters approved successfully")).build();
    }

    @Transactional
    public AdminPortalResponse<String> rejectMaster(MasterApproveRejectRequest request, String masterCode) {
        MasterType master = MasterType.getMasterType(masterCode);
        BaseMasterService<BaseMasterDto> service = masterHandlerFactory.getMasterService(master.name());
        List<UUID> ids = request.getRecords().stream().map(MasterApproveRejectRequest.RecordItem::getMasterId).toList();
        List<BaseMasterDto> masters = service.findByIds(ids);
//        service.validateForApprove(masters);
        service.reject(ids);
        request.getRecords().forEach(record -> masterWorkFlowService.rejectWorkFlow(master, record));
        return AdminPortalResponse.<String>builder().status(SUCCESS_RESPONSE_CODE).data(List.of("Masters rejected successfully")).build();
    }
    @Transactional
    public AdminPortalResponse<String> inactivateMaster(MasterInactivationRequest request, String masterCode) {
        MasterType master = MasterType.getMasterType(masterCode);
        BaseMasterService<BaseMasterDto> service = masterHandlerFactory.getMasterService(master.name());
        List<BaseMasterDto> masters = service.findByIds(request.getMasterIds());
//        service.validateForInactivation(masters);
        service.markPendingForInactivation(request.getMasterIds());
        masters.forEach(masterDto -> {
            MasterWorkFlowDto workflow = service.mapToMasterWorkFlowDto(masterDto);
            workflow.setAction(WorkflowAction.INACTIVATE.name());
            workflow.setStatus(WorkflowAction.PENDING_FOR_INACTIVATION.name());
            workflow.setRemark(request.getRemarks());
            masterWorkFlowService.save(workflow, WorkflowOperation.INACTIVATION);
        });
        return AdminPortalResponse.<String>builder().status(SUCCESS_RESPONSE_CODE).data(List.of("Masters submitted for inactivation successfully")).build();
    }

}
