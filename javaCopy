public class AdminMasterService {

    private final MasterWorkflowDao masterWorkflowDao;
    private final MasterHandlerFactory handlerFactory;
    private final MasterBulkUploadService masterBulkUploadService;
    private final ObjectMapper objectMapper;
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());

    public AdminPortalResponse<WorkflowResponse> submitCreate(String masterType, Object dto) {
        MasterType master = MasterType.getMasterType(masterType);
        log.info("Submitting create workflow for masterType={}", master);
        MasterHandler<?, ?> handler = handlerFactory.getHandler(master);
        MasterWorkflow wf = buildWorkflow(handler, dto, null);
        masterWorkflowDao.save(wf);
        log.info("Create workflow submitted successfully for masterType={} with workflowId={}", master, wf.getId());
        return AdminPortalResponse.<WorkflowResponse>builder().status(SUCCESS_RESPONSE_CODE).data(List.of(WorkflowResponse.builder().message("Request submitted").status("PENDING").workflowId(wf.getId()).build())).build();
    }
    private <T> MasterWorkflow buildWorkflow(MasterHandler<T, ?> handler, Object request, UUID id) {
        T dto = convertRequest(handler, request);
        if(id == null){
            handler.validateCreate(dto);
        }else{
            handler.validateUpdate(dto);}
        return handler.toWorkflow(dto, id);
    }
}

@Component
public class MasterHandlerFactory {
    private final LoggerUtility log = LoggerFactoryUtility.getLogger(this.getClass());
    private final Map<MasterType, MasterHandler<?, ?>> handlerMap = new EnumMap<>(MasterType.class);

    @Autowired
    public MasterHandlerFactory(List<MasterHandler<?, ?>> handlers) {
        handlers.forEach(handler -> {
             if (handler instanceof ConstitutionHandler) {
                handlerMap.put(MasterType.CONSTITUTION, handler);
                log.info("Registered handler={} for masterType={}", handler.getClass().getSimpleName(), MasterType.CONSTITUTION);
            }
        });
    }

 
    public MasterHandler<?, ?> getHandler(MasterType masterType) {
        MasterHandler<?, ?> handler = handlerMap.get(masterType);
        if (handler == null) {
            log.warn("No handler registered for masterType={}", masterType);
            throw new AdminPortalException(NOT_FOUND_ERROR_CODE, MessageFormat.format(NOT_FOUND_ERROR_MESSAGE, "Handler for master type " + masterType));
        }
        return handler;
    }
}

