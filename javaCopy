CREATE TABLE MASTER_TABLE (
    ID RAW(16) DEFAULT SYS_GUID() PRIMARY KEY NOT NULL,
    MASTER_TYPE VARCHAR2(100) NOT NULL,
    NAME VARCHAR2(255) NOT NULL,
    IS_BULK_ALLOWED NUMBER(1) DEFAULT 0 NOT NULL,
    IS_MAKER_CHECKER_ENABLED NUMBER(1) DEFAULT 1 NOT NULL,
    IS_HEADER_PRESENT NUMBER(1) DEFAULT 1 NOT NULL,
    FILE_EXTENSION VARCHAR2(20) DEFAULT 'csv' NOT NULL,
    DELIMITER VARCHAR2(5) DEFAULT ',' NOT NULL,
    CHARSET_NAME VARCHAR2(50) DEFAULT 'UTF-8' NOT NULL,
    FILE_FORMAT_CONFIG CLOB NOT NULL,
    FILE_CHECKSUM VARCHAR2(500),
    STATUS VARCHAR2(50) NOT NULL,
    DESCRIPTION VARCHAR2(500),
    CREATED_BY VARCHAR2(100) NOT NULL,
    CREATED_AT NUMBER NOT NULL,
    UPDATED_BY VARCHAR2(100) NOT NULL,
    UPDATED_AT NUMBER NOT NULL,
    CONSTRAINT UK_MASTER_TABLE_MASTER_TYPE UNIQUE (MASTER_TYPE)
);

CREATE TABLE MASTER_FILE_UPLOAD (
    ID RAW(16) DEFAULT SYS_GUID() PRIMARY KEY NOT NULL,
    MASTER_TYPE VARCHAR2(100) NOT NULL,
    FILE_NAME VARCHAR2(255) NOT NULL,
    TOTAL_RECORD NUMBER DEFAULT 0,
    SUCCESS_RECORD NUMBER DEFAULT 0,
    FAILED_RECORD NUMBER DEFAULT 0,
    FILE_CHECKSUM VARCHAR2(500) NOT NULL,
    STATUS VARCHAR2(50) NOT NULL,
    ERROR_MESSAGE VARCHAR2(2000),
    REMARK VARCHAR2(500),
    CREATED_BY VARCHAR2(100) NOT NULL,
    CREATED_AT NUMBER NOT NULL,
    UPDATED_BY VARCHAR2(100) NOT NULL,
    UPDATED_AT NUMBER NOT NULL
);

CREATE TABLE MASTER_FILE_UPLOAD_DTLS (
    ID RAW(16) DEFAULT SYS_GUID() PRIMARY KEY NOT NULL,
    MASTER_FILE_UPLOAD_ID RAW(16) NOT NULL,
    RECORD_JSON CLOB NOT NULL,
    STATUS VARCHAR2(50) NOT NULL,
    ERROR_MESSAGE VARCHAR2(2000),
    REMARK VARCHAR2(500),
    CREATED_BY VARCHAR2(100) NOT NULL,
    CREATED_AT NUMBER NOT NULL,
    UPDATED_BY VARCHAR2(100) NOT NULL,
    UPDATED_AT NUMBER NOT NULL,
    CONSTRAINT FK_MASTER_FILE_UPLOAD_DTLS_UPLOAD FOREIGN KEY (MASTER_FILE_UPLOAD_ID)
        REFERENCES MASTER_FILE_UPLOAD (ID)
);

CREATE INDEX IDX_MASTER_FILE_UPLOAD_TYPE ON MASTER_FILE_UPLOAD (MASTER_TYPE);
CREATE INDEX IDX_MASTER_FILE_UPLOAD_CHKSUM ON MASTER_FILE_UPLOAD (MASTER_TYPE, FILE_CHECKSUM);
CREATE INDEX IDX_MASTER_FILE_UPLOAD_DTLS_UPLOAD ON MASTER_FILE_UPLOAD_DTLS (MASTER_FILE_UPLOAD_ID);

