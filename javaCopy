package com.epay.admin.portal.validator;

import com.epay.admin.portal.master.dto.CountryCurrencyDTO;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Component;

import java.util.ArrayList;

@Component
@RequiredArgsConstructor
public class CountryCurrencyValidator extends BaseValidator {

    public void validateRequest(CountryCurrencyDTO dto){
        errorDtoList = new ArrayList<>();
        checkMandatoryField(dto.getCountryCode(),"");
        checkMandatoryField(dto.getCurrency(),"");
        checkMandatoryField(dto.getCountryName(),"");
        checkMandatoryField(dto.getCurrencyCode(),"");
        throwIfErrors();
        checkForLeadingTrailingAndSingleSpace(dto.getCountryCode(), "");
        checkForLeadingTrailingAndSingleSpace(dto.getCountryName(),"" );
        checkForLeadingTrailingAndSingleSpace(dto.getCurrency(), "");
        checkForLeadingTrailingAndSingleSpace(dto.getCurrencyCode(),"");
        throwIfErrors();
    }

}
