@Component
@RequiredArgsConstructor
public class ConstitutionHandler implements MasterHandler<ConstitutionDTO, Constitution> {

    private final ConstitutionRepository repo;
    private final CountryCurrencyRepository countryRepo;
    private final MasterWorkflowRepository masterWorkflowRepository;
    private final ObjectMapper mapper;

    @Override
    public void validateCreate(ConstitutionDTO dto) {
        if (!repo.existsByConstitutionName(dto.getConstitution_name()))
            throw new AdminPortalException("1001","Constitution code exists");
    }
    @Override
    public void validateUpdate(ConstitutionDTO dto) {
        // similar checks as needed
    }
    @Override
    public MasterWorkflow toWorkflow(ConstitutionDTO dto, UUID id) throws JsonProcessingException {
        Constitution entity = new Constitution();
        entity.setConstitutionName(dto.getConstitution_name());
        entity.setConstitutionCode(MasterUtil.generateMasterCode(dto.getConstitution_name(), MasterType.CONSTITUTION));
        entity.setCreatedAt(System.currentTimeMillis());
        entity.setCreatedBy(EPayIdentityUtil.getUserPrincipal().getUsername());
        String newVal = mapper.writeValueAsString(entity);
        String oldVal = null;
        if (id != null) {
            Constitution old = repo.findById(id).orElseThrow();
            oldVal =  mapper.writeValueAsString(old);
        }
        MasterWorkflow wf = new MasterWorkflow();
        wf.setMasterType(MasterType.CONSTITUTION);
        wf.setRecordId(id);
        wf.setNewValue(newVal);
        wf.setOldValue(oldVal);
        wf.setStatus(WorkflowStatus.PENDING);
        wf.setActionType("MAKER");
        wf.setMakerId(EPayIdentityUtil.getUserPrincipal().getUsername());
        return wf;
    }

    @Override
    public void applyApproved(MasterWorkflow wf) throws JsonProcessingException {
        Constitution data = mapper.readValue(wf.getNewValue(), Constitution.class);
        if (wf.getRecordId() != null) {
            data.setId(wf.getRecordId());
        }
        repo.save(data);
        wf.setStatus(WorkflowStatus.APPROVED);
    }

    @Override
    public AdminPortalResponse<?> search(Object request, Pageable pageable) {
        ConstitutionSearchRequest req = mapper.convertValue(request, ConstitutionSearchRequest.class);
        Specification<Constitution> spec = ConstitutionSpecification.build(req);
        List<ConstitutionResponse> constitutionResponseList = Stream.concat(
                        repo.findAll(spec).stream().map(this::toResponse),
                        getUnapprovedWorkflowResponses(req).stream()
                )
                .toList();

        List<ConstitutionResponse> sortedResponses = sortResponses(constitutionResponseList, pageable);
        long total = sortedResponses.size();
        int start = Math.toIntExact(pageable.getOffset());
        int end = Math.min(start + pageable.getPageSize(), sortedResponses.size());
        List<ConstitutionResponse> pagedResponses = start >= sortedResponses.size()
                ? Collections.emptyList()
                : sortedResponses.subList(start, end);

        return AdminPortalResponse.<ConstitutionResponse>builder()
                .status(SUCCESS_RESPONSE_CODE)
                .data(pagedResponses)
                .count((long) pagedResponses.size())
                .total(total)
                .build();
    }

    private List<ConstitutionResponse> getUnapprovedWorkflowResponses(ConstitutionSearchRequest req) {
        return masterWorkflowRepository.findAllByMasterTypeAndStatusNot(MasterType.CONSTITUTION, WorkflowStatus.APPROVED)
                .stream()
                .filter(workflow -> matchesWorkflowFilter(workflow, req))
                .map(this::toWorkflowResponse)
                .toList();
    }

    private boolean matchesWorkflowFilter(MasterWorkflow workflow, ConstitutionSearchRequest req) {
        try {
            Constitution constitution = mapper.readValue(workflow.getNewValue(), Constitution.class);
            if (StringUtils.isNotBlank(req.getConstitutionName())
                    && !StringUtils.containsIgnoreCase(constitution.getConstitutionName(), req.getConstitutionName())) {
                return false;
            }
            if (StringUtils.isNotBlank(req.getStatus())
                    && !StringUtils.equalsIgnoreCase(workflow.getStatus().name(), req.getStatus())
                    && !StringUtils.equalsIgnoreCase(constitution.getStatus(), req.getStatus())) {
                return false;
            }

            Long createdAt = constitution.getCreatedAt() != null ? constitution.getCreatedAt() : workflow.getCreatedAt();
            if (req.getFromDate() != null && (createdAt == null || createdAt < req.getFromDate())) {
                return false;
            }
            return req.getToDate() == null || (createdAt != null && createdAt <= req.getToDate());
        } catch (JsonProcessingException e) {
            throw new AdminPortalException("1001", "Invalid constitution workflow data");
        }
    }

    private ConstitutionResponse toWorkflowResponse(MasterWorkflow workflow) {
        try {
            Constitution constitution = mapper.readValue(workflow.getNewValue(), Constitution.class);
            ConstitutionResponse response = toResponse(constitution);
            response.getConstitutionMaster().setId(workflow.getRecordId());

            ConstitutionResponse.MasterWorkflowData workflowData = new ConstitutionResponse.MasterWorkflowData();
            workflowData.setWorkflowId(workflow.getId());
            workflowData.setConstitutionCode(constitution.getConstitutionCode());
            workflowData.setStatus(workflow.getStatus().name());
            workflowData.setCreatedBy(workflow.getMakerId());
            workflowData.setUpdatedBy(workflow.getCheckerId());
            workflowData.setCreatedAt(workflow.getCreatedAt());
            response.setMasterWorkflow(workflowData);
            return response;
        } catch (JsonProcessingException e) {
            throw new AdminPortalException("1001", "Invalid constitution workflow data");
        }
    }

    private ConstitutionResponse toResponse(Constitution entity) {
        ConstitutionResponse response = new ConstitutionResponse();
        ConstitutionResponse.ConstitutionMaster constitutionMaster = new ConstitutionResponse.ConstitutionMaster();
        constitutionMaster.setId(entity.getId());
        constitutionMaster.setConstitutionName(entity.getConstitutionName());
        constitutionMaster.setConstitutionCode(entity.getConstitutionCode());
        constitutionMaster.setStatus(entity.getStatus());
        constitutionMaster.setCreatedBy(entity.getCreatedBy());
        constitutionMaster.setUpdatedBy(entity.getUpdatedBy());
        constitutionMaster.setCreatedAt(entity.getCreatedAt());
        response.setConstitutionMaster(constitutionMaster);
        return response;
    }

    private List<ConstitutionResponse> sortResponses(List<ConstitutionResponse> responses, Pageable pageable) {
        if (pageable.getSort().isUnsorted()) {
            return responses;
        }

        return responses.stream()
                .sorted(buildComparator(pageable))
                .toList();
    }

    private Comparator<ConstitutionResponse> buildComparator(Pageable pageable) {
        Comparator<ConstitutionResponse> comparator = null;
        for (org.springframework.data.domain.Sort.Order order : pageable.getSort()) {
            Comparator<ConstitutionResponse> orderComparator = Comparator.comparing(
                    response -> getComparableValue(response, order.getProperty()),
                    Comparator.nullsLast(Comparator.naturalOrder())
            );
            if (order.isDescending()) {
                orderComparator = orderComparator.reversed();
            }
            comparator = comparator == null ? orderComparator : comparator.thenComparing(orderComparator);
        }
        return comparator == null
                ? Comparator.comparing(
                        response -> getComparableValue(response, "constitutionMaster.constitutionName"),
                        Comparator.nullsLast(Comparator.naturalOrder())
                )
                : comparator;
    }

    @SuppressWarnings("unchecked")
    private Comparable<Object> getComparableValue(ConstitutionResponse response, String property) {
        Object value = new BeanWrapperImpl(response).getPropertyValue(resolveSortProperty(property));
        if (value instanceof String stringValue) {
            return (Comparable<Object>) stringValue.toLowerCase(Locale.ROOT);
        }
        return (Comparable<Object>) value;
    }

    private String resolveSortProperty(String property) {
        return switch (property) {
            case "id" -> "constitutionMaster.id";
            case "constitutionName" -> "constitutionMaster.constitutionName";
            case "status" -> "constitutionMaster.status";
            case "createdBy" -> "constitutionMaster.createdBy";
            case "updatedBy" -> "constitutionMaster.updatedBy";
            case "createdAt" -> "constitutionMaster.createdAt";
            case "workflowId" -> "masterWorkflow.workflowId";
            default -> property;
        };
    }

