package com.epay.admin.portal.repository.admin;

import com.epay.admin.portal.entity.admin.MIFJourneySteps;
import com.epay.admin.portal.util.enums.OnboardingStage;
import com.epay.admin.portal.util.enums.StageStatus;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.util.Optional;
import java.util.UUID;

@Repository
public interface MIFJourneyStepsRepository extends JpaRepository<MIFJourneySteps, UUID> {
    @Query("""
            SELECT CASE WHEN COUNT(js.stepNum) = COUNT(sm.stepNum)
            THEN true ELSE false END 
            FROM StepMaster sm 
            LEFT JOIN MIFJourneySteps js
            ON sm.stepNum =js.stepNum
            AND js.journeyId = :journeyId
            AND js.status = 'COMPLETED'
            WHERE sm.stageNum = :stageNum
            """)
    boolean areAllStepsCompleted(UUID journeyId,int stageNum);

    @Query("""
            SELECT js.status
            FROM MIFJourneySteps js
            WHERE js.merchantMifId = :merchantMifId
              AND js.journeyId = (
                    SELECT mj.id
                    FROM MIFJourney mj
                    WHERE mj.merchantMIFId = :merchantMifId
                      AND mj.stageNum = (
                            SELECT stm.stageNum
                            FROM StageMaster stm
                            WHERE stm.stageCode = :stage
                      )
              )
              AND js.stepNum = (
                    SELECT sm.prevStep
                    FROM StepMaster sm
                    WHERE sm.stepCode = :stepCode
              )
            """)
    Optional<StageStatus> findPreviousStepStatus(@Param("merchantMifId") String merchantMifId,
                                                 @Param("stage") OnboardingStage stage,
                                                 @Param("stepCode") String stepCode);

    Optional<MIFJourneySteps> findByMerchantMifIdAndJourneyIdAndStepCode(String merchantMifId, UUID journeyId, String stepCode);
}

